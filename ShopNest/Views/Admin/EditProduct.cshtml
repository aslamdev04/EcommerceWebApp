@model ShopNest.Models.ViewModels.ProductViewModel
@{
    ViewData["Title"] = "Edit Product";
    Layout = "~/Views/Shared/_Admin.cshtml";
}

<div class="cnt page-anim">
    <div class="zpill adm">
        <i class="fa-solid fa-shield-halved"></i> Admin Zone
    </div>

    <div class="ph">
        <div>
            <h1>Edit Product</h1>
            <p>Update product details below.</p>
        </div>
        <div class="ph-acts">
            <a asp-controller="Admin"
               asp-action="Product_mon"
               class="btn-sn btn-o">
                <i class="fa-solid fa-arrow-left"></i> Back
            </a>
        </div>
    </div>

    <div style="max-width:700px;margin:0 auto">
        <div class="card-sn">
            <div class="ch">
                <div class="d-flex align-items-center gap-3">
                    <div style="width:40px;height:40px;border-radius:10px;
                        background:linear-gradient(135deg,var(--blue),var(--cyan));
                        display:flex;align-items:center;
                        justify-content:center;font-size:16px;color:#fff">
                        <i class="fa-solid fa-pen"></i>
                    </div>
                    <div>
                        <h5 style="margin:0;font-size:16px;font-weight:700">
                            Edit Product
                        </h5>
                        <div style="font-size:12px;color:var(--t3)">
                            #P-@ViewBag.ProductId.ToString("D4")
                        </div>
                    </div>
                </div>
            </div>

            <div class="cb">
                <form asp-controller="Admin"
                      asp-action="EditProduct"
                      asp-route-id="@ViewBag.ProductId"
                      method="post"
                      enctype="multipart/form-data">

                    @Html.AntiForgeryToken()

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger"
                             style="font-size:13px;border-radius:10px">
                            @Html.ValidationSummary(false)
                        </div>
                    }

                    <div class="row g-3">

                        @* Product Name *@
                        <div class="col-12">
                            <label class="flbl">Product Name</label>
                            <input asp-for="Name"
                                   class="finp"
                                   placeholder="e.g. iPhone 15 Pro Max" />
                            <span asp-validation-for="Name"
                                  class="text-danger"
                                  style="font-size:11px"></span>
                        </div>

                        @* Category + Price *@
                        <div class="col-md-6">
                            <label class="flbl">Category</label>
                            <select asp-for="CategoryId"
                                    asp-items="ViewBag.Categories"
                                    class="finp">
                                <option value="">-- Select Category --</option>
                            </select>
                            <span asp-validation-for="CategoryId"
                                  class="text-danger"
                                  style="font-size:11px"></span>
                        </div>

                        <div class="col-md-6">
                            <label class="flbl">Price (₹)</label>
                            <input asp-for="Price"
                                   type="number"
                                   class="finp"
                                   placeholder="e.g. 999" />
                            <span asp-validation-for="Price"
                                  class="text-danger"
                                  style="font-size:11px"></span>
                        </div>

                        @* Stock *@
                        <div class="col-12">
                            <label class="flbl">Stock Quantity</label>
                            <input asp-for="Stock"
                                   type="number"
                                   class="finp"
                                   placeholder="e.g. 50" />
                            <span asp-validation-for="Stock"
                                  class="text-danger"
                                  style="font-size:11px"></span>
                        </div>

                        @* Description *@
                        <div class="col-12">
                            <label class="flbl">Description</label>
                            <textarea asp-for="Description"
                                      class="finp"
                                      rows="3"
                                      placeholder="Write product description..."
                                      style="resize:none"></textarea>
                        </div>

                        @* Existing Image *@
                        @if (ViewBag.ExistingImage != null)
                        {
                            <div class="col-12">
                                <label class="flbl">Current Image</label>
                                <div>
                                    <img src="@ViewBag.ExistingImage"
                                         style="height:80px;border-radius:8px;
                                    object-fit:cover;
                                    border:1px solid var(--bdr)" />
                                </div>
                            </div>
                        }

                        @* New Image Upload *@
                        <div class="col-12">
                            <label class="flbl">
                                Change Image
                                <span style="color:var(--t3);font-weight:400">
                                    (optional)
                                </span>
                            </label>
                            <div style="border:2px dashed var(--bdr);
                                border-radius:10px;padding:20px;
                                text-align:center;cursor:pointer;
                                background:var(--bg2)"
                                 onclick="document.getElementById('imgInput').click()">
                                <div id="imgPreview">
                                    <i class="fa-solid fa-cloud-arrow-up"
                                       style="font-size:24px;color:var(--t3)"></i>
                                    <div style="font-size:13px;color:var(--t3);
                                        margin-top:8px">
                                        Click to upload new image
                                    </div>
                                </div>
                                <img id="imgThumb"
                                     src="#"
                                     style="display:none;max-height:120px;
                                border-radius:8px" />
                            </div>
                            <input type="file"
                                   id="imgInput"
                                   name="ImageFile"
                                   accept="image/*"
                                   style="display:none"
                                   onchange="previewImage(this)" />
                        </div>

                    </div>

                    @* Buttons *@
                    <div class="d-flex gap-2 mt-4">
                        <a asp-controller="Admin"
                           asp-action="Product_mon"
                           class="btn-sn btn-o">
                            <i class="fa-solid fa-xmark"></i> Cancel
                        </a>
                        <button type="submit" class="btn-sn btn-p">
                            <i class="fa-solid fa-floppy-disk"></i> Save Changes
                        </button>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    document.getElementById('imgThumb').src = e.target.result;
                    document.getElementById('imgThumb').style.display = 'block';
                    document.getElementById('imgPreview').style.display = 'none';
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}