@model List<ShopNest.Models.ViewModels.ProductMonViewModel>
@{
    ViewData["Title"] = "Product_mon";
    Layout = "~/Views/Shared/_Admin.cshtml";
}

<div class="cnt page-anim">

    <div class="zpill adm">
        <i class="fa-solid fa-shield-halved"></i> Admin Zone
    </div>
    <div class="ph">
        <div>
            <h1>Product Monitoring</h1>
            <p>Monitor inventory, pricing, and product performance.</p>
        </div>
        <div class="ph-acts">
            <button class="btn-sn btn-o">
                <i class="fa-solid fa-filter"></i> Filter
            </button>
            <a asp-controller="Admin" asp-action="Index"
               class="btn-sn btn-p">
                <i class="fa-solid fa-plus"></i> Add Product
            </a>
        </div>
    </div>

    @* ── Stats Cards ── *@
    <div class="sg mb-18"
         style="grid-template-columns:repeat(auto-fit,minmax(160px,1fr))">
        <div class="sc gr">
            <div class="sc-top">
                <div class="sc-ico gr"><i class="fa-solid fa-circle-check"></i></div>
            </div>
            <div class="sc-val">@ViewBag.InStock</div>
            <div class="sc-lbl">In Stock</div>
        </div>
        <div class="sc am">
            <div class="sc-top">
                <div class="sc-ico am">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                </div>
            </div>
            <div class="sc-val">@ViewBag.LowStock</div>
            <div class="sc-lbl">Low Stock</div>
        </div>
        <div class="sc ro">
            <div class="sc-top">
                <div class="sc-ico ro"><i class="fa-solid fa-ban"></i></div>
            </div>
            <div class="sc-val">@ViewBag.OutOfStock</div>
            <div class="sc-lbl">Out of Stock</div>
        </div>
        <div class="sc bl">
            <div class="sc-top">
                <div class="sc-ico bl">
                    <i class="fa-solid fa-boxes-stacked"></i>
                </div>
            </div>
            <div class="sc-val">@ViewBag.TotalProducts</div>
            <div class="sc-lbl">Total Products</div>
        </div>
    </div>

    @* ── Table Card ── *@
    <div class="card-sn">

        @* Success/Error Messages *@
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success mx-3 mt-3"
                 style="border-radius:10px;font-size:13px">
                <i class="fa-solid fa-circle-check"></i>
                @TempData["Success"]
            </div>
        }

        @* Filter Bar *@
        <div class="tf">
            <div class="ts">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input type="text" id="searchInput"
                       placeholder="Search products…"
                       onkeyup="filterTable()" />
            </div>
            <select class="tsel" id="categoryFilter" onchange="filterTable()">
                <option value="">All Categories</option>
                @foreach (var cat in ViewBag.Categories)
                {
                    <option value="@cat">@cat</option>
                }
            </select>
            <select class="tsel" id="stockFilter" onchange="filterTable()">
                <option value="">All Stock</option>
                <option value="In Stock">In Stock</option>
                <option value="Low Stock">Low Stock</option>
                <option value="Out of Stock">Out of Stock</option>
            </select>
        </div>

        @* Table *@
        <div class="table-responsive">
            <table class="dt" id="productTable">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Product</th>
                        <th>Category</th>
                        <th>Price</th>
                        <th>Stock</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center"
                                style="padding:40px;color:var(--t3)">
                                <i class="fa-solid fa-box-open"
                                   style="font-size:32px;margin-bottom:8px"></i>
                                <div>No products found</div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var p in Model)
                        {
                            <tr>
                                @* ID *@
                                <td style="font-family:var(--mono);
                                    font-size:11.5px;color:var(--t3)">
                                    #P-@p.ProductId
                                </td>

                                @* Product Name + Icon *@
                                <td>
                                    <div class="cc">
                                        <div style="font-size:20px">
                                            @p.CategoryIcon
                                        </div>
                                        <div>
                                            <div class="cn">@p.Name</div>
                                        </div>
                                    </div>
                                </td>

                                @* Category *@
                                <td>@p.CategoryName</td>

                                @* Price *@
                                <td>
                                    <span style="font-family:var(--mono);
                                        font-weight:700">
                                        ₹@p.Price
                                    </span>
                                </td>

                                @* Stock *@
                                <td>
                                    <span style="font-family:var(--mono);
                                        font-weight:700;
                                        color:@p.StockColor">
                                        @p.Stock
                                    </span>
                                </td>

                                @* Status Badge *@
                                <td>
                                    <span class="bdg @p.StockBadgeClass">
                                        @p.StockStatus
                                    </span>
                                </td>

                                @* Actions *@
                                <td>
                                    <div class="abtns">
                                        @* View *@
                                        <button class="abtn v"
                                                title="View">
                                            <i class="fa-solid fa-eye"></i>
                                        </button>

                                        @* Edit *@
                                        <a asp-controller="Admin"
                                           asp-action="EditProduct"
                                           asp-route-id="@p.ProductId"
                                           class="abtn e"
                                           title="Edit">
                                            <i class="fa-solid fa-pen"></i>
                                        </a>

                                        @* Delete *@
                                        <form asp-controller="Admin"
                                              asp-action="DeleteProduct"
                                              method="post"
                                              style="display:inline"
                                              onsubmit="return confirm('Delete @p.Name?')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden"
                                                   name="id"
                                                   value="@p.ProductId" />
                                            <button type="submit"
                                                    class="abtn d"
                                                    title="Delete">
                                                <i class="fa-solid fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        @* Pagination Info *@
        <div class="pgn">
            <div class="pgn-info">
                Showing @Model.Count products
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Search + Filter
        function filterTable() {
            var search   = document.getElementById('searchInput')
                                   .value.toLowerCase();
            var category = document.getElementById('categoryFilter')
                                   .value.toLowerCase();
            var stock    = document.getElementById('stockFilter')
                                   .value.toLowerCase();

            var rows = document.querySelectorAll('#productTable tbody tr');

            rows.forEach(function (row) {
                var name    = row.cells[1]?.innerText.toLowerCase() || '';
                var cat     = row.cells[2]?.innerText.toLowerCase() || '';
                var status  = row.cells[5]?.innerText.toLowerCase() || '';

                var matchSearch   = name.includes(search);
                var matchCategory = category === '' || cat.includes(category);
                var matchStock    = stock === '' || status.includes(stock);

                row.style.display = (matchSearch && matchCategory && matchStock)
                                    ? '' : 'none';
            });
        }
    </script>
}