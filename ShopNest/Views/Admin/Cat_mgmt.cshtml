@model List<ShopNest.Models.Category>
@{
    ViewData["Title"] = "Cat_mgmt";
    Layout = "~/Views/Shared/_Admin.cshtml";
}

<div class="cnt page-anim">

    <div class="zpill adm">
        <i class="fa-solid fa-shield-halved"></i> Admin Zone
    </div>

    <div class="ph">
        <div>
            <h1>Category Management</h1>
            <p>Manage product categories and subcategories.</p>
        </div>
        <div class="ph-acts">
            <button class="btn-sn btn-p"
                    data-bs-toggle="modal"
                    data-bs-target="#addCategoryModal">
                <i class="fa-solid fa-plus"></i> Add Category
            </button>
        </div>
    </div>

    @* Messages *@
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success mb-3"
             style="border-radius:10px;font-size:13px">
            <i class="fa-solid fa-circle-check"></i> @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger mb-3"
             style="border-radius:10px;font-size:13px">
            <i class="fa-solid fa-circle-exclamation"></i> @TempData["Error"]
        </div>
    }

    @* Category Cards Grid *@
    <div class="g4">

        @foreach (var cat in Model)
        {
            <div class="card-sn" style="cursor:pointer">
                <div class="cb" style="text-align:center;padding:24px 16px">

                    @* Icon *@
                    <div style="font-size:36px;margin-bottom:10px">
                        @cat.Icon
                    </div>

                    @* Name *@
                    <div style="font-size:14px;font-weight:700">
                        @cat.CategoryName
                    </div>

                    @* Product Count *@
                    <div style="font-size:12px;color:var(--t3);margin-top:4px">
                        @(((Dictionary<int, int>)ViewBag.ProductCounts)
                            .GetValueOrDefault(cat.CategoryId, 0)) products
                    </div>

                    @* Status Badge *@
                    <div class="mt-3">
                        <span class="bdg @(cat.IsActive ? "bdg-active" : "bdg-inactive")">
                            @(cat.IsActive ? "Active" : "Inactive")
                        </span>
                    </div>

                    @* Action Buttons *@
                    <div class="d-flex gap-2 justify-content-center mt-3">

                        @* Toggle Active *@
                        <form asp-controller="Admin"
                              asp-action="ToggleCategory"
                              method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@cat.CategoryId" />
                            <button type="submit"
                                    class="abtn @(cat.IsActive ? "v" : "e")"
                                    title="@(cat.IsActive ? "Deactivate" : "Activate")">
                                <i class="fa-solid @(cat.IsActive ?
                                                                              "fa-toggle-on" : "fa-toggle-off")"></i>
                            </button>
                        </form>

                        @* Delete *@
                        <form asp-controller="Admin"
                              asp-action="DeleteCategory"
                              method="post"
                              onsubmit="return confirm('Delete @cat.CategoryName?')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@cat.CategoryId" />
                            <button type="submit"
                                    class="abtn d"
                                    title="Delete">
                                <i class="fa-solid fa-trash"></i>
                            </button>
                        </form>

                    </div>
                </div>
            </div>
        }

        @* Add New Card *@
        <div class="card-sn"
             style="cursor:pointer;border-style:dashed"
             data-bs-toggle="modal"
             data-bs-target="#addCategoryModal">
            <div class="cb" style="text-align:center;padding:24px 16px">
                <div style="font-size:36px;margin-bottom:10px;color:var(--t3)">+</div>
                <div style="font-size:14px;font-weight:700;color:var(--t3)">
                    Add Category
                </div>
                <div style="font-size:12px;color:var(--t3);margin-top:4px">
                    Create new
                </div>
            </div>
        </div>

    </div>
</div>

@* ── Add Category Modal ───────────────────────────────── *@
<div class="modal fade" id="addCategoryModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content"
             style="border-radius:16px;border:1px solid var(--bdr)">

            @* Header *@
            <div class="modal-header"
                 style="padding:20px 24px 16px;border-bottom:1px solid var(--bdr)">
                <div class="d-flex align-items-center gap-3">
                    <div style="width:40px;height:40px;border-radius:10px;
                        background:linear-gradient(135deg,var(--blue),var(--cyan));
                        display:flex;align-items:center;
                        justify-content:center;font-size:16px;color:#fff">
                        <i class="fa-solid fa-tags"></i>
                    </div>
                    <div>
                        <h5 style="margin:0;font-size:16px;font-weight:700">
                            Add New Category
                        </h5>
                        <div style="font-size:12px;color:var(--t3)">
                            Fill in the details below
                        </div>
                    </div>
                </div>
                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal"></button>
            </div>

            @* Body *@
            <div class="modal-body" style="padding:24px">
                <form asp-controller="Admin"
                      asp-action="AddCategory"
                      method="post"
                      id="addCategoryForm">

                    @Html.AntiForgeryToken()

                    <div class="row g-3">

                        @* Icon *@
                        <div class="col-4">
                            <label class="flbl">Icon (Emoji)</label>
                            <input name="Icon"
                                   class="finp text-center"
                                   placeholder="📦"
                                   style="font-size:24px"
                                   maxlength="2"
                                   required />
                        </div>

                        @* Category Name *@
                        <div class="col-8">
                            <label class="flbl">Category Name</label>
                            <input name="CategoryName"
                                   class="finp"
                                   placeholder="e.g. Electronics"
                                   required />
                        </div>

                        @* Is Active *@
                        <div class="col-12">
                            <label class="d-flex align-items-center gap-2"
                                   style="font-size:13px;cursor:pointer">
                                <input type="checkbox"
                                       name="IsActive"
                                       value="true"
                                       checked />
                                Set as Active
                            </label>
                        </div>

                    </div>
                </form>
            </div>

            @* Footer *@
            <div class="modal-footer"
                 style="padding:16px 24px;border-top:1px solid var(--bdr)">
                <button type="button"
                        class="btn-sn btn-o"
                        data-bs-dismiss="modal">
                    <i class="fa-solid fa-xmark"></i> Cancel
                </button>
                <button type="submit"
                        form="addCategoryForm"
                        class="btn-sn btn-p">
                    <i class="fa-solid fa-plus"></i> Add Category
                </button>
            </div>

        </div>
    </div>
</div>