
@{
    ViewData["Title"] = "Cat_mgmt";
    Layout = "~/Views/Shared/_Admin.cshtml";
}

<div class="cnt page-anim">

    <div class="zpill adm"><i class="fa-solid fa-shield-halved"></i> Admin Zone</div>
    <div class="ph">
