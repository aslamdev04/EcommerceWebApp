        <div class="card-sn" style="cursor:pointer"><div class="cb" style="text-align:center;padding:24px 16px"><div style="font-size:36px;margin-bottom:10px">👗</div><div style="font-size:14px;font-weight:700">Fashion</div><div style="font-size:12px;color:var(--t3);margin-top:4px">980 products</div><div class="mt-3"><span class="bdg bdg-active">Active</span></div></div></div>
        <div class="card-sn" style="cursor:pointer"><div class="cb" style="text-align:center;padding:24px 16px"><div style="font-size:36px;margin-bottom:10px">🏠</div><div style="font-size:14px;font-weight:700">Home &amp; Living</div><div style="font-size:12px;color:var(--t3);margin-top:4px">640 products</div><div class="mt-3"><span class="bdg bdg-active">Active</span></div></div></div>
        <div class="card-sn" style="cursor:pointer"><div class="cb" style="text-align:center;padding:24px 16px"><div style="font-size:36px;margin-bottom:10px">💄</div><div style="font-size:14px;font-weight:700">Beauty</div><div style="font-size:12px;color:var(--t3);margin-top:4px">420 products</div><div class="mt-3"><span class="bdg bdg-active">Active</span></div></div></div>
        <div class="card-sn" style="cursor:pointer"><div class="cb" style="text-align:center;padding:24px 16px"><div style="font-size:36px;margin-bottom:10px">📚</div><div style="font-size:14px;font-weight:700">Books</div><div style="font-size:12px;color:var(--t3);margin-top:4px">380 products</div><div class="mt-3"><span class="bdg bdg-active">Active</span></div></div></div>
        <div class="card-sn" style="cursor:pointer"><div class="cb" style="text-align:center;padding:24px 16px"><div style="font-size:36px;margin-bottom:10px">🏋️</div><div style="font-size:14px;font-weight:700">Sports</div><div style="font-size:12px;color:var(--t3);margin-top:4px">310 products</div><div class="mt-3"><span class="bdg bdg-active">Active</span></div></div></div>
        <div class="card-sn" style="cursor:pointer"><div class="cb" style="text-align:center;padding:24px 16px"><div style="font-size:36px;margin-bottom:10px">🍕</div><div style="font-size:14px;font-weight:700">Food &amp; Grocery</div><div style="font-size:12px;color:var(--t3);margin-top:4px">210 products</div><div class="mt-3"><span class="bdg bdg-inactive">Inactive</span></div></div></div>
        <div class="card-sn" style="cursor:pointer;border-style:dashed"><div class="cb" style="text-align:center;padding:24px 16px"><div style="font-size:36px;margin-bottom:10px;color:var(--t3)">+</div><div style="font-size:14px;font-weight:700;color:var(--t3)">Add Category</div><div style="font-size:12px;color:var(--t3);margin-top:4px">Create new</div></div></div>
