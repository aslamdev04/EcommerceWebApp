@model List<ShopNest.Models.ViewModels.OrderMgmtViewModel>
@{
    ViewData["Title"] = "Order_mgmt";
    Layout = "~/Views/Shared/_Admin.cshtml";
    string selected = ViewBag.SelectedStatus ?? "All";
}

<div class="cnt page-anim">

    <div class="zpill adm">
        <i class="fa-solid fa-shield-halved"></i> Admin Zone
    </div>

    <div class="ph">
        <div>
            <h1>Order Management</h1>
            <p>Manage all customer orders and update their statuses.</p>
        </div>
        <div class="ph-acts">
            <button class="btn-sn btn-o">
                <i class="fa-solid fa-download"></i> Export
            </button>
        </div>
    </div>

    @* Messages *@
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success mb-3"
             style="border-radius:10px;font-size:13px">
            <i class="fa-solid fa-circle-check"></i> @TempData["Success"]
        </div>
    }

    @* ── Stats Cards ── *@
    <div class="sg mb-18"
         style="grid-template-columns:repeat(auto-fit,minmax(150px,1fr))">
        <div class="sc am">
            <div class="sc-top">
                <div class="sc-ico am">
                    <i class="fa-solid fa-hourglass-half"></i>
                </div>
            </div>
            <div class="sc-val">@ViewBag.PendingCount</div>
            <div class="sc-lbl">Pending</div>
        </div>
        <div class="sc bl">
            <div class="sc-top">
                <div class="sc-ico bl"><i class="fa-solid fa-gear"></i></div>
            </div>
            <div class="sc-val">@ViewBag.ProcessingCount</div>
            <div class="sc-lbl">Processing</div>
        </div>
        <div class="sc cy">
            <div class="sc-top">
                <div class="sc-ico cy"><i class="fa-solid fa-truck"></i></div>
            </div>
            <div class="sc-val">@ViewBag.ShippedCount</div>
            <div class="sc-lbl">Shipped</div>
        </div>
        <div class="sc gr">
            <div class="sc-top">
                <div class="sc-ico gr">
                    <i class="fa-solid fa-circle-check"></i>
                </div>
            </div>
            <div class="sc-val">@ViewBag.DeliveredCount</div>
            <div class="sc-lbl">Delivered</div>
        </div>
        <div class="sc ro">
            <div class="sc-top">
                <div class="sc-ico ro"><i class="fa-solid fa-ban"></i></div>
            </div>
            <div class="sc-val">@ViewBag.CancelledCount</div>
            <div class="sc-lbl">Cancelled</div>
        </div>
    </div>

    <div class="card-sn">

        @* ── Status Tabs ── *@
        <div class="tabr">
            <a asp-action="Order_mgmt" asp-route-status="All"
               class="tabb @(selected == "All" ? "on" : "")">
                All Orders
            </a>
            <a asp-action="Order_mgmt" asp-route-status="Pending"
               class="tabb @(selected == "Pending" ? "on" : "")">
                Pending (@ViewBag.PendingCount)
            </a>
            <a asp-action="Order_mgmt" asp-route-status="Processing"
               class="tabb @(selected == "Processing" ? "on" : "")">
                Processing (@ViewBag.ProcessingCount)
            </a>
            <a asp-action="Order_mgmt" asp-route-status="Shipped"
               class="tabb @(selected == "Shipped" ? "on" : "")">
                Shipped (@ViewBag.ShippedCount)
            </a>
            <a asp-action="Order_mgmt" asp-route-status="Delivered"
               class="tabb @(selected == "Delivered" ? "on" : "")">
                Delivered
            </a>
            <a asp-action="Order_mgmt" asp-route-status="Cancelled"
               class="tabb @(selected == "Cancelled" ? "on" : "")">
                Cancelled
            </a>
        </div>

        @* ── Search Bar ── *@
        <div class="tf">
            <div class="ts">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input type="text"
                       id="orderSearch"
                       placeholder="Search by order ID, customer…"
                       onkeyup="searchOrders()" />
            </div>
            <select class="tsel" id="dateFilter" onchange="searchOrders()">
                <option value="">All Dates</option>
                <option value="today">Today</option>
                <option value="week">This Week</option>
                <option value="month">This Month</option>
            </select>
        </div>

        @* ── Table ── *@
        <div class="table-responsive">
            <table class="dt" id="ordersTable">
                <thead>
                    <tr>
                        <th>Order ID</th>
                        <th>Customer</th>
                        <th>Items</th>
                        <th>Amount</th>
                        <th>Date</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7"
                                class="text-center"
                                style="padding:40px;color:var(--t3)">
                                <i class="fa-solid fa-box-open"
                                   style="font-size:32px;margin-bottom:8px"></i>
                                <div>No orders found</div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var order in Model)
                        {
                            <tr>
                                @* Order ID *@
                                <td style="font-family:var(--mono);font-size:12px;
                                    color:var(--blue);font-weight:700">
                                    #ORD-@order.OrderId.ToString("D4")
                                </td>

                                @* Customer *@
                                <td>
                                    <div class="cc">
                                        <div class="cav"
                                             style="@order.AvatarColor">
                                            @order.CustomerInitials
                                        </div>
                                        <div>
                                            <div class="cn">
                                                @order.CustomerName
                                            </div>
                                        </div>
                                    </div>
                                </td>

                                @* Items *@
                                <td>@order.ItemCount items</td>

                                @* Amount *@
                                <td>
                                    <span style="font-family:var(--mono);
                                        font-weight:700">
                                        ₹@order.TotalAmount.ToString("N0")
                                    </span>
                                </td>

                                @* Date *@
                                <td style="font-size:12.5px;color:var(--t3)">
                                    @order.FormattedDate
                                </td>

                                @* Status *@
                                <td>
                                    <span class="bdg @order.StatusBadgeClass">
                                        @order.Status
                                    </span>
                                </td>

                                @* Actions *@
                                <td>
                                    <div class="abtns">

                                        @* View *@
                                        <button class="abtn v"
                                                title="View Details">
                                            <i class="fa-solid fa-eye"></i>
                                        </button>

                                        @* Status Update Dropdown *@
                                        <div class="dropdown d-inline">
                                            <button class="abtn e dropdown-toggle"
                                                    data-bs-toggle="dropdown"
                                                    title="Update Status">
                                                <i class="fa-solid fa-pen"></i>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end"
                                                style="font-size:13px;min-width:160px">
                                                @foreach (var s in new[]
                                                {
                                                    "Pending",
                                                    "Processing",
                                                    "Shipped",
                                                    "Delivered",
                                                    "Cancelled"
                                                })
                                                {
                                                    <li>
                                                        <form asp-controller="Admin"
                                                              asp-action="UpdateOrderStatus"
                                                              method="post">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden"
                                                                   name="orderId"
                                                                   value="@order.OrderId" />
                                                            <input type="hidden"
                                                                   name="status"
                                                                   value="@s" />
                                                            <button type="submit"
                                                                    class="dropdown-item
                                                                @(order.Status == s
                                                                        ? "active" : "")">
                                                                @s
                                                            </button>
                                                        </form>
                                                    </li>
                                                }
                                            </ul>
                                        </div>

                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        @* Pagination Info *@
        <div class="pgn">
            <div class="pgn-info">
                Showing @Model.Count orders
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        function searchOrders() {
            var input = document.getElementById('orderSearch')
                                .value.toLowerCase();
            var rows  = document.querySelectorAll('#ordersTable tbody tr');

            rows.forEach(function (row) {
                var text = row.innerText.toLowerCase();
                row.style.display = text.includes(input) ? '' : 'none';
            });
        }
    </script>
}