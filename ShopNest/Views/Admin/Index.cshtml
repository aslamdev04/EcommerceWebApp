
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Admin.cshtml";
}

<div class="cnt page-anim">

    <div class="zpill adm"><i class="fa-solid fa-shield-halved"></i> Admin Zone</div>
    <div class="ph">
        <div><h1>Admin Dashboard</h1><p>Welcome back. Here's your store overview for today.</p></div>
        <div class="ph-acts">
            <button class="btn-sn btn-o"><i class="fa-solid fa-download"></i> Export</button>
            <button class="btn-sn btn-p"><i class="fa-solid fa-plus"></i> Add Product</button>
        </div>
    </div>
    <div class="sg">
        <div class="sc bl"><div class="sc-top"><div class="sc-ico bl"><i class="fa-solid fa-users"></i></div><div class="sc-tr up"><i class="fa-solid fa-arrow-trend-up"></i>+11%</div></div><div class="sc-val">18,420</div><div class="sc-lbl">Total Users</div><div class="sc-sub"><i class="fa-solid fa-circle-info"></i>&nbsp;312 new this month</div></div>
        <div class="sc gr"><div class="sc-top"><div class="sc-ico gr"><i class="fa-solid fa-boxes-stacked"></i></div><div class="sc-tr up"><i class="fa-solid fa-arrow-trend-up"></i>+6%</div></div><div class="sc-val">4,280</div><div class="sc-lbl">Total Products</div><div class="sc-sub"><i class="fa-solid fa-circle-info"></i>&nbsp;18 low stock items</div></div>
        <div class="sc am"><div class="sc-top"><div class="sc-ico am"><i class="fa-solid fa-receipt"></i></div><div class="sc-tr up"><i class="fa-solid fa-arrow-trend-up"></i>+19%</div></div><div class="sc-val">9,641</div><div class="sc-lbl">Total Orders</div><div class="sc-sub"><i class="fa-solid fa-circle-info"></i>&nbsp;34 pending today</div></div>
        <div class="sc ro"><div class="sc-top"><div class="sc-ico ro"><i class="fa-solid fa-indian-rupee-sign"></i></div><div class="sc-tr up"><i class="fa-solid fa-arrow-trend-up"></i>+24%</div></div><div class="sc-val">₹84.2K</div><div class="sc-lbl">Total Revenue</div><div class="sc-sub"><i class="fa-solid fa-circle-info"></i>&nbsp;₹12.4K earned today</div></div>
        <div class="sc cy"><div class="sc-top"><div class="sc-ico cy"><i class="fa-solid fa-cart-shopping"></i></div><div class="sc-tr dn"><i class="fa-solid fa-arrow-trend-down"></i>-3%</div></div><div class="sc-val">₹8,742</div><div class="sc-lbl">Avg. Order Value</div><div class="sc-sub"><i class="fa-solid fa-circle-info"></i>&nbsp;vs ₹9,012 last month</div></div>
        <div class="sc vi"><div class="sc-top"><div class="sc-ico vi"><i class="fa-solid fa-star"></i></div><div class="sc-tr up"><i class="fa-solid fa-arrow-trend-up"></i>+0.2</div></div><div class="sc-val">4.7</div><div class="sc-lbl">Avg. Rating</div><div class="sc-sub"><i class="fa-solid fa-circle-info"></i>&nbsp;6,214 reviews</div></div>
        <div class="sc or"><div class="sc-top"><div class="sc-ico or"><i class="fa-solid fa-rotate-left"></i></div><div class="sc-tr dn"><i class="fa-solid fa-arrow-trend-down"></i>-1.2%</div></div><div class="sc-val">2.8%</div><div class="sc-lbl">Return Rate</div></div>
        <div class="sc bk"><div class="sc-top"><div class="sc-ico bk"><i class="fa-solid fa-percent"></i></div><div class="sc-tr up"><i class="fa-solid fa-arrow-trend-up"></i>+4.1%</div></div><div class="sc-val">31.6%</div><div class="sc-lbl">Conversion Rate</div></div>
    </div>
    <div class="g3 mb-18">
        <div class="card-sn">
            <div class="ch"><h3><i class="fa-solid fa-chart-column"></i> Monthly Revenue</h3><select class="tsel"><option>2026</option><option>2025</option></select></div>
            <div class="cb">
                <div class="d-flex gap-3 mb-3" style="font-size:12px;color:var(--t3)">
                    <span class="d-flex align-items-center gap-2"><span style="width:10px;height:10px;border-radius:3px;background:var(--blue);display:inline-block"></span>Revenue</span>
                    <span class="d-flex align-items-center gap-2"><span style="width:10px;height:10px;border-radius:3px;background:var(--cyan);display:inline-block"></span>Orders</span>
                </div>
                <div class="bch">
                    <div class="bcol"><div class="bbar" style="height:52%"></div><div class="bval">₹58K</div><div class="blbl">Jan</div></div>
                    <div class="bcol"><div class="bbar alt" style="height:20%"></div><div class="bval">720</div><div class="blbl"></div></div>
                    <div class="bcol"><div class="bbar" style="height:65%"></div><div class="bval">₹72K</div><div class="blbl">Feb</div></div>
                    <div class="bcol"><div class="bbar alt" style="height:28%"></div><div class="bval">980</div><div class="blbl"></div></div>
                    <div class="bcol"><div class="bbar" style="height:80%"></div><div class="bval">₹84K</div><div class="blbl">Mar</div></div>
                    <div class="bcol"><div class="bbar alt" style="height:38%"></div><div class="bval">1.2K</div><div class="blbl"></div></div>
                    <div class="bcol"><div class="bbar" style="height:60%"></div><div class="bval">₹67K</div><div class="blbl">Apr</div></div>
                    <div class="bcol"><div class="bbar alt" style="height:25%"></div><div class="bval">840</div><div class="blbl"></div></div>
                    <div class="bcol"><div class="bbar" style="height:92%"></div><div class="bval">₹98K</div><div class="blbl">May</div></div>
                    <div class="bcol"><div class="bbar alt" style="height:44%"></div><div class="bval">1.4K</div><div class="blbl"></div></div>
                </div>
            </div>
        </div>
        <div class="card-sn">
            <div class="ch"><h3><i class="fa-solid fa-bolt"></i> Today's Stats</h3></div>
            <div class="cb">
                <div class="mini-r"><div class="mini-ico" style="background:var(--blue-l);color:var(--blue)"><i class="fa-solid fa-eye"></i></div><div class="mini-lbl">Page Views</div><div class="mini-val">24,180</div></div>
                <div class="mini-r"><div class="mini-ico" style="background:#d1fae5;color:var(--emerald)"><i class="fa-solid fa-cart-plus"></i></div><div class="mini-lbl">New Orders</div><div class="mini-val">142</div></div>
                <div class="mini-r"><div class="mini-ico" style="background:#fef3c7;color:var(--amber)"><i class="fa-solid fa-user-plus"></i></div><div class="mini-lbl">New Signups</div><div class="mini-val">38</div></div>
                <div class="mini-r"><div class="mini-ico" style="background:#ffe4e6;color:var(--rose)"><i class="fa-solid fa-triangle-exclamation"></i></div><div class="mini-lbl">Low Stock Alerts</div><div class="mini-val">18</div></div>
                <div class="mini-r"><div class="mini-ico" style="background:#cffafe;color:var(--cyan)"><i class="fa-solid fa-indian-rupee-sign"></i></div><div class="mini-lbl">Revenue Today</div><div class="mini-val">₹12.4K</div></div>
            </div>
        </div>
    </div>
    <div class="g2">
        <div class="card-sn">
            <div class="ch"><h3><i class="fa-solid fa-chart-pie"></i> Orders by Status</h3><span class="bdg bdg-active">This Month</span></div>
            <div class="cb">
                <div class="dnut-wrap">
                    <div class="dnut"><div class="dnut-c"><strong>9.6K</strong><span>Orders</span></div></div>
                    <div class="dleg">
                        <div class="dleg-i"><div class="dleg-dot" style="background:var(--blue)"></div>Processing<span class="dleg-val">2,840</span></div>
                        <div class="dleg-i"><div class="dleg-dot" style="background:var(--emerald)"></div>Delivered<span class="dleg-val">5,120</span></div>
                        <div class="dleg-i"><div class="dleg-dot" style="background:var(--amber)"></div>Shipped<span class="dleg-val">1,210</span></div>
                        <div class="dleg-i"><div class="dleg-dot" style="background:var(--rose)"></div>Cancelled<span class="dleg-val">471</span></div>
                    </div>
                </div>
                <div class="mt-3">
                    <div class="prg"><div class="prg-lbl"><span>Processing</span><span>29%</span></div><div class="prg-bg"><div class="prg-fill bl" style="width:29%"></div></div></div>
                    <div class="prg"><div class="prg-lbl"><span>Delivered</span><span>53%</span></div><div class="prg-bg"><div class="prg-fill gr" style="width:53%"></div></div></div>
                    <div class="prg"><div class="prg-lbl"><span>Shipped</span><span>13%</span></div><div class="prg-bg"><div class="prg-fill am" style="width:13%"></div></div></div>
                    <div class="prg"><div class="prg-lbl"><span>Cancelled</span><span>5%</span></div><div class="prg-bg"><div class="prg-fill ro" style="width:5%"></div></div></div>
                </div>
            </div>
        </div>
        <div class="card-sn">
            <div class="ch"><h3><i class="fa-solid fa-clock-rotate-left"></i> Recent Activity</h3><button class="btn-sn btn-o btn-sm">View All</button></div>
            <div class="cb">
                <div class="act-i"><div class="act-ico b"><i class="fa-solid fa-user-plus"></i></div><div><div class="act-txt"><strong>Priya Sharma</strong> registered as new customer</div><div class="act-time">5 mins ago</div></div></div>
                <div class="act-i"><div class="act-ico g"><i class="fa-solid fa-receipt"></i></div><div><div class="act-txt">Order <strong>#ORD-8821</strong> marked as Delivered</div><div class="act-time">22 mins ago</div></div></div>
                <div class="act-i"><div class="act-ico a"><i class="fa-solid fa-triangle-exclamation"></i></div><div><div class="act-txt">Product <strong>iPhone 15 Pro</strong> is low on stock (3 left)</div><div class="act-time">1 hr ago</div></div></div>
                <div class="act-i"><div class="act-ico r"><i class="fa-solid fa-rotate-left"></i></div><div><div class="act-txt">Return request for Order <strong>#ORD-7904</strong></div><div class="act-time">2 hrs ago</div></div></div>
                <div class="act-i"><div class="act-ico c"><i class="fa-solid fa-tag"></i></div><div><div class="act-txt">New offer <strong>SUMMER25</strong> activated</div><div class="act-time">3 hrs ago</div></div></div>
            </div>
        </div>
    </div>
</div>

