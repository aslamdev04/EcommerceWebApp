
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Admin.cshtml";
}
@model ShopNest.Models.ViewModels.ProductViewModel
@* Dashboard div se pehle add karo *@ 
@if (TempData["Success"] != null)
{
    <div class="alert alert-success d-flex align-items-center gap-2"
         style="border-radius:10px;font-size:13px;margin-bottom:16px">
        <i class="fa-solid fa-circle-check"></i>
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger d-flex align-items-center gap-2"
         style="border-radius:10px;font-size:13px;margin-bottom:16px">
        <i class="fa-solid fa-circle-exclamation"></i>
        @TempData["Error"]
    </div>
}
<div class="cnt page-anim">

    <div class="zpill adm"><i class="fa-solid fa-shield-halved"></i> Admin Zone</div>
    <div class="ph">
        <div><h1>Admin Dashboard</h1><p>Welcome back. Here's your store overview for today.</p></div>
        <div class="ph-acts">
            <button class="btn-sn btn-o"><i class="fa-solid fa-download"></i> Export</button>
            <button class="btn-sn btn-p"
                    data-bs-toggle="modal"
                    data-bs-target="#addProductModal">
                <i class="fa-solid fa-plus"></i> Add Product
            </button>
        </div>
    </div>
    @* Yeh hardcoded values replace karo *@
    <div class="sg">
        <div class="sc bl">
            <div class="sc-top">
                <div class="sc-ico bl"><i class="fa-solid fa-users"></i></div>
                <div class="sc-tr up">
                    <i class="fa-solid fa-arrow-trend-up"></i>
                </div>
            </div>
            <div class="sc-val">@ViewBag.TotalUsers</div>
            <div class="sc-lbl">Total Users</div>
            <div class="sc-sub">
                <i class="fa-solid fa-circle-info"></i>&nbsp;Registered customers
            </div>
        </div>

        <div class="sc gr">
            <div class="sc-top">
                <div class="sc-ico gr">
                    <i class="fa-solid fa-boxes-stacked"></i>
                </div>
            </div>
            <div class="sc-val">@ViewBag.TotalProducts</div>
            <div class="sc-lbl">Total Products</div>
            <div class="sc-sub">
                <i class="fa-solid fa-circle-info"></i>
                &nbsp;@ViewBag.LowStockCount low stock items
            </div>
        </div>

        <div class="sc am">
            <div class="sc-top">
                <div class="sc-ico am"><i class="fa-solid fa-receipt"></i></div>
            </div>
            <div class="sc-val">@ViewBag.TotalOrders</div>
            <div class="sc-lbl">Total Orders</div>
            <div class="sc-sub">
                <i class="fa-solid fa-circle-info"></i>
                &nbsp;@ViewBag.PendingOrders pending today
            </div>
        </div>

        <div class="sc ro">
            <div class="sc-top">
                <div class="sc-ico ro">
                    <i class="fa-solid fa-indian-rupee-sign"></i>
                </div>
            </div>
            <div class="sc-val">
                ₹@((ViewBag.TotalRevenue / 1000m).ToString("0.0"))K
            </div>
            <div class="sc-lbl">Total Revenue</div>
            <div class="sc-sub">
                <i class="fa-solid fa-circle-info"></i>&nbsp;All time revenue
            </div>
        </div>
    </div>
    <div class="g3 mb-18">
        <div class="card-sn">
            <div class="ch"><h3><i class="fa-solid fa-chart-column"></i> Monthly Revenue</h3><select class="tsel"><option>2026</option><option>2025</option></select></div>
            <div class="cb">
                <div class="d-flex gap-3 mb-3" style="font-size:12px;color:var(--t3)">
                    <span class="d-flex align-items-center gap-2"><span style="width:10px;height:10px;border-radius:3px;background:var(--blue);display:inline-block"></span>Revenue</span>
                    <span class="d-flex align-items-center gap-2"><span style="width:10px;height:10px;border-radius:3px;background:var(--cyan);display:inline-block"></span>Orders</span>
                </div>
                <div class="bch">
                    <div class="bcol"><div class="bbar" style="height:52%"></div><div class="bval">₹58K</div><div class="blbl">Jan</div></div>
                    <div class="bcol"><div class="bbar alt" style="height:20%"></div><div class="bval">720</div><div class="blbl"></div></div>
                    <div class="bcol"><div class="bbar" style="height:65%"></div><div class="bval">₹72K</div><div class="blbl">Feb</div></div>
                    <div class="bcol"><div class="bbar alt" style="height:28%"></div><div class="bval">980</div><div class="blbl"></div></div>
                    <div class="bcol"><div class="bbar" style="height:80%"></div><div class="bval">₹84K</div><div class="blbl">Mar</div></div>
                    <div class="bcol"><div class="bbar alt" style="height:38%"></div><div class="bval">1.2K</div><div class="blbl"></div></div>
                    <div class="bcol"><div class="bbar" style="height:60%"></div><div class="bval">₹67K</div><div class="blbl">Apr</div></div>
                    <div class="bcol"><div class="bbar alt" style="height:25%"></div><div class="bval">840</div><div class="blbl"></div></div>
                    <div class="bcol"><div class="bbar" style="height:92%"></div><div class="bval">₹98K</div><div class="blbl">May</div></div>
                    <div class="bcol"><div class="bbar alt" style="height:44%"></div><div class="bval">1.4K</div><div class="blbl"></div></div>
                </div>
            </div>
        </div>
        <div class="card-sn">
            <div class="ch"><h3><i class="fa-solid fa-bolt"></i> Today's Stats</h3></div>
            <div class="cb">
                <div class="mini-r"><div class="mini-ico" style="background:var(--blue-l);color:var(--blue)"><i class="fa-solid fa-eye"></i></div><div class="mini-lbl">Page Views</div><div class="mini-val">24,180</div></div>
                <div class="mini-r"><div class="mini-ico" style="background:#d1fae5;color:var(--emerald)"><i class="fa-solid fa-cart-plus"></i></div><div class="mini-lbl">New Orders</div><div class="mini-val">142</div></div>
                <div class="mini-r"><div class="mini-ico" style="background:#fef3c7;color:var(--amber)"><i class="fa-solid fa-user-plus"></i></div><div class="mini-lbl">New Signups</div><div class="mini-val">38</div></div>
                <div class="mini-r"><div class="mini-ico" style="background:#ffe4e6;color:var(--rose)"><i class="fa-solid fa-triangle-exclamation"></i></div><div class="mini-lbl">Low Stock Alerts</div><div class="mini-val">18</div></div>
                <div class="mini-r"><div class="mini-ico" style="background:#cffafe;color:var(--cyan)"><i class="fa-solid fa-indian-rupee-sign"></i></div><div class="mini-lbl">Revenue Today</div><div class="mini-val">₹12.4K</div></div>
            </div>
        </div>
    </div>
    <div class="g2">
        <div class="card-sn">
            <div class="ch"><h3><i class="fa-solid fa-chart-pie"></i> Orders by Status</h3><span class="bdg bdg-active">This Month</span></div>
            <div class="cb">
                <div class="dnut-wrap">
                    <div class="dnut"><div class="dnut-c"><strong>9.6K</strong><span>Orders</span></div></div>
                    @* Donut chart section mein real data *@
                    <div class="dleg">
                        <div class="dleg-i">
                            <div class="dleg-dot" style="background:var(--blue)"></div>
                            Processing
                            <span class="dleg-val">@ViewBag.ProcessingOrders</span>
                        </div>
                        <div class="dleg-i">
                            <div class="dleg-dot" style="background:var(--emerald)"></div>
                            Delivered
                            <span class="dleg-val">@ViewBag.DeliveredOrders</span>
                        </div>
                        <div class="dleg-i">
                            <div class="dleg-dot" style="background:var(--amber)"></div>
                            Shipped
                            <span class="dleg-val">@ViewBag.ShippedOrders</span>
                        </div>
                        <div class="dleg-i">
                            <div class="dleg-dot" style="background:var(--rose)"></div>
                            Cancelled
                            <span class="dleg-val">@ViewBag.CancelledOrders</span>
                        </div>
                    </div>

                    @* Progress bars *@
                    @{
                        int total = ViewBag.TotalOrders > 0 ? (int)ViewBag.TotalOrders : 1;
                        int processingPct = (int)((ViewBag.ProcessingOrders / (double)total) * 100);
                        int deliveredPct = (int)((ViewBag.DeliveredOrders / (double)total) * 100);
                        int shippedPct = (int)((ViewBag.ShippedOrders / (double)total) * 100);
                        int cancelledPct = (int)((ViewBag.CancelledOrders / (double)total) * 100);
                    }

                    <div class="prg">
                        <div class="prg-lbl">
                            <span>Processing</span><span>@processingPct%</span>
                        </div>
                        <div class="prg-bg">
                            <div class="prg-fill bl" style="width:@processingPct%"></div>
                        </div>
                    </div>
                    <div class="prg">
                        <div class="prg-lbl">
                            <span>Delivered</span><span>@deliveredPct%</span>
                        </div>
                        <div class="prg-bg">
                            <div class="prg-fill gr" style="width:@deliveredPct%"></div>
                        </div>
                    </div>
                    <div class="prg">
                        <div class="prg-lbl">
                            <span>Shipped</span><span>@shippedPct%</span>
                        </div>
                        <div class="prg-bg">
                            <div class="prg-fill am" style="width:@shippedPct%"></div>
                        </div>
                    </div>
                    <div class="prg">
                        <div class="prg-lbl">
                            <span>Cancelled</span><span>@cancelledPct%</span>
                        </div>
                        <div class="prg-bg">
                            <div class="prg-fill ro" style="width:@cancelledPct%"></div>
                        </div>
                    </div>
                </div>
                <div class="mt-3">
                    <div class="prg"><div class="prg-lbl"><span>Processing</span><span>29%</span></div><div class="prg-bg"><div class="prg-fill bl" style="width:29%"></div></div></div>
                    <div class="prg"><div class="prg-lbl"><span>Delivered</span><span>53%</span></div><div class="prg-bg"><div class="prg-fill gr" style="width:53%"></div></div></div>
                    <div class="prg"><div class="prg-lbl"><span>Shipped</span><span>13%</span></div><div class="prg-bg"><div class="prg-fill am" style="width:13%"></div></div></div>
                    <div class="prg"><div class="prg-lbl"><span>Cancelled</span><span>5%</span></div><div class="prg-bg"><div class="prg-fill ro" style="width:5%"></div></div></div>
                </div>
            </div>
        </div>
        <div class="card-sn">
            <div class="ch"><h3><i class="fa-solid fa-clock-rotate-left"></i> Recent Activity</h3><button class="btn-sn btn-o btn-sm">View All</button></div>
            @* Recent Activity — Real Orders *@
            <div class="cb">
                @if (ViewBag.RecentOrders != null)
                {
                    @foreach (var order in ViewBag.RecentOrders)
                    {
                        <div class="act-i">
                            <div class="act-ico g">
                                <i class="fa-solid fa-receipt"></i>
                            </div>
                            <div>
                                <div class="act-txt">
                                    Order <strong>#ORD-@order.OrderId.ToString("D4")</strong>
                                    by <strong>@order.CustomerName</strong>
                                    — ₹@order.Amount.ToString("N0")
                                </div>
                                <div class="act-time">
                                    @order.Date ·
                                    <span class="bdg bdg-@order.Status.ToLower()">
                                        @order.Status
                                    </span>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>
@* ─── ADD PRODUCT MODAL ─────────────────────────────────── *@
<div class="modal fade" id="addProductModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content" style="border-radius:16px;border:1px solid var(--bdr)">

            @* Modal Header *@
            <div class="modal-header"
                 style="padding:20px 24px 16px;border-bottom:1px solid var(--bdr)">
                <div class="d-flex align-items-center gap-3">
                    <div style="width:40px;height:40px;border-radius:10px;
                        background:linear-gradient(135deg,var(--blue),var(--cyan));
                        display:flex;align-items:center;justify-content:center;
                        font-size:16px;color:#fff">
                        <i class="fa-solid fa-boxes-stacked"></i>
                    </div>
                    <div>
                        <h5 style="margin:0;font-size:16px;font-weight:700">
                            Add New Product
                        </h5>
                        <div style="font-size:12px;color:var(--t3)">
                            Fill in the details below
                        </div>
                    </div>
                </div>
                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal"></button>
            </div>

            @* Modal Body *@
            <div class="modal-body" style="padding:24px">
                <form asp-controller="Admin"
                      asp-action="AddProduct"
                      method="post"
                      enctype="multipart/form-data"
                      id="addProductForm">

                    @Html.AntiForgeryToken()

                    @* Validation Summary *@
                    <div id="productErrors"
                         class="alert alert-danger d-none"
                         style="font-size:13px"></div>

                    <div class="row g-3">

                        @* Product Name *@
                        <div class="col-12">
                            <label class="flbl">Product Name</label>
                            <input asp-for="Name"
                                   class="finp"
                                   placeholder="e.g. iPhone 15 Pro Max" />
                            <span asp-validation-for="Name"
                                  class="text-danger"
                                  style="font-size:11px"></span>
                        </div>

                        @* Category + Price *@
                        <div class="col-md-6">
                            <label class="flbl">Category</label>
                            <select asp-for="CategoryId"
                                    asp-items="ViewBag.Categories"
                                    class="finp">
                                <option value="">-- Select Category --</option>
                            </select>
                            <span asp-validation-for="CategoryId"
                                  class="text-danger"
                                  style="font-size:11px"></span>
                        </div>

                        <div class="col-md-6">
                            <label class="flbl">Price (₹)</label>
                            <input asp-for="Price"
                                   type="number"
                                   class="finp"
                                   placeholder="e.g. 999" />
                            <span asp-validation-for="Price"
                                  class="text-danger"
                                  style="font-size:11px"></span>
                        </div>

                        @* Stock + SKU *@
                        <div class="col-md-6">
                            <label class="flbl">Stock Quantity</label>
                            <input asp-for="Stock"
                                   type="number"
                                   class="finp"
                                   placeholder="e.g. 50" />
                            <span asp-validation-for="Stock"
                                  class="text-danger"
                                  style="font-size:11px"></span>
                        </div>

                        @* <div class="col-md-6">
                            <label class="flbl">SKU Code</label>
                            <input asp-for="SKU"
                                   class="finp"
                                   placeholder="e.g. IPH-15-PRO-256" />
                            <span asp-validation-for="SKU"
                                  class="text-danger"
                                  style="font-size:11px"></span>
                        </div> *@

                        @* Description *@
                        <div class="col-12">
                            <label class="flbl">Description</label>
                            <textarea asp-for="Description"
                                      class="finp"
                                      rows="3"
                                      placeholder="Write product description..."
                                      style="resize:none"></textarea>
                            <span asp-validation-for="Description"
                                  class="text-danger"
                                  style="font-size:11px"></span>
                        </div>

                        @* Image Upload *@
                        <div class="col-12">
                            <label class="flbl">Product Image</label>
                            <div style="border:2px dashed var(--bdr);
                                border-radius:10px;padding:20px;
                                text-align:center;cursor:pointer;
                                background:var(--bg2)"
                                 onclick="document.getElementById('imgInput').click()">
                                <div id="imgPreview">
                                    <i class="fa-solid fa-cloud-arrow-up"
                                       style="font-size:24px;color:var(--t3)"></i>
                                    <div style="font-size:13px;color:var(--t3);margin-top:8px">
                                        Click to upload image
                                    </div>
                                    <div style="font-size:11px;color:var(--t3)">
                                        PNG, JPG up to 5MB
                                    </div>
                                </div>
                                <img id="imgThumb"
                                     src="#"
                                     style="display:none;max-height:120px;
                                border-radius:8px" />
                            </div>
                            <input type="file"
                                   id="imgInput"
                                   name="ImageFile"
                                   accept="image/*"
                                   style="display:none"
                                   onchange="previewImage(this)" />
                        </div>

                    </div>
                </form>
            </div>

            @* Modal Footer *@
            <div class="modal-footer"
                 style="padding:16px 24px;border-top:1px solid var(--bdr)">
                <button type="button"
                        class="btn-sn btn-o"
                        data-bs-dismiss="modal">
                    <i class="fa-solid fa-xmark"></i> Cancel
                </button>
                <button type="submit"
                        form="addProductForm"
                        class="btn-sn btn-p">
                    <i class="fa-solid fa-plus"></i> Add Product
                </button>
            </div>

        </div>
    </div>
</div>

@* Image Preview Script *@
@section Scripts {
    <script>
        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    document.getElementById('imgThumb').src = e.target.result;
                    document.getElementById('imgThumb').style.display = 'block';
                    document.getElementById('imgPreview').style.display = 'none';
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}
