<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title</title>

    @* Bootstrap 5.3 CDN *@
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/Customer.css" asp-append-version="true" />
</head>
<body>
    <div class="overlay" id="ov" onclick="document.getElementById('sb').classList.remove('open');this.classList.remove('show')"></div>
    <aside class="sb" id="sb">
        <div class="sb-logo">
            <div class="sb-logo-mark"><i class="fa-solid fa-basket-shopping"></i></div>
            <div class="sb-logo-text"><strong>ShopNest</strong><span>E-Commerce Portal</span></div>
        </div>
        <div class="sb-zone">
            <span class="sb-zone-lbl">Portal Zone</span>
            <div class="sb-zone-row">

                @* Sirf Admin ko dikhao *@
                @if (User.IsInRole("Admin"))
                {
                    <a asp-controller="Admin"
                       asp-action="Index"
                       class="zb"
                       style="text-decoration:none">Admin</a>
                }

                @* Customer always on kyunki yeh Customer layout hai *@
                <a asp-controller="Customer"
                   asp-action="Index"
                   class="zb on"
                   style="text-decoration:none">Customer</a>

                @* General hamesha dikhega *@
                <a asp-controller="Home"
                   asp-action="Index"
                   class="zb"
                   style="text-decoration:none">General</a>

            </div>
        </div>
        <nav class="sb-nav">

            @* Overview *@
            <div class="sb-sec">
                <div class="sb-sec-t">Overview</div>
                <a asp-controller="Customer"
                   asp-action="Index"
                   class="sb-item on">
                    <span class="si">
                        <i class="fa-solid fa-gauge-high"></i>
                    </span>
                    My Dashboard
                </a>
            </div>

            @* Shopping *@
            <div class="sb-sec">
                <div class="sb-sec-t">Shopping</div>
                <a asp-controller="Customer"
                   asp-action="Browse"
                   class="sb-item">
                    <span class="si">
                        <i class="fa-solid fa-shop"></i>
                    </span>
                    Browse Products
                </a>

                @* Cart — Real Count *@
                <a asp-controller="Customer"
                   asp-action="Cart"
                   class="sb-item">
                    <span class="si">
                        <i class="fa-solid fa-cart-shopping"></i>
                    </span>
                    My Cart
                    @if (ViewBag.CartCount != null && ViewBag.CartCount > 0)
                    {
                        <span class="sb-bdg r">@ViewBag.CartCount</span>
                    }
                </a>

                <a asp-controller="Customer"
                   asp-action="Checkout"
                   class="sb-item">
                    <span class="si">
                        <i class="fa-solid fa-bag-shopping"></i>
                    </span>
                    Checkout
                </a>
            </div>

            @* Orders *@
            <div class="sb-sec">
                <div class="sb-sec-t">Orders</div>
                <a asp-controller="Customer"
                   asp-action="MyOrders"
                   class="sb-item">
                    <span class="si">
                        <i class="fa-solid fa-box-archive"></i>
                    </span>
                    My Orders
                    @if (ViewBag.TotalOrders != null && ViewBag.TotalOrders > 0)
                    {
                        <span class="sb-bdg b">@ViewBag.TotalOrders</span>
                    }
                </a>
                <a asp-controller="Customer"
                   asp-action="Order_track"
                   class="sb-item">
                    <span class="si">
                        <i class="fa-solid fa-route"></i>
                    </span>
                    Track Order
                </a>
                <a asp-controller="Customer"
                   asp-action="Reviews"
                   class="sb-item">
                    <span class="si">
                        <i class="fa-solid fa-star"></i>
                    </span>
                    Reviews & Feedback
                </a>
            </div>

            @* Account *@
            <div class="sb-sec">
                <div class="sb-sec-t">Account</div>
                <a asp-controller="Customer"
                   asp-action="Profile"
                   class="sb-item">
                    <span class="si">
                        <i class="fa-solid fa-user-circle"></i>
                    </span>
                    My Profile
                </a>
                <a asp-controller="Customer"
                   asp-action="Notifications"
                   class="sb-item">
                    <span class="si">
                        <i class="fa-solid fa-bell"></i>
                    </span>
                    Notifications
                    @if (ViewBag.PendingOrders != null &&
                         ViewBag.PendingOrders > 0)
                    {
                        <span class="sb-bdg a">@ViewBag.PendingOrders</span>
                    }
                </a>
            </div>

        </nav>
@* Sidebar footer — real user *@
<div class="sb-foot">
    <div class="sb-usr">
        <div class="sb-av">
            @(User.Identity?.Name?.Length > 1
                ? User.Identity.Name.Substring(0, 2).ToUpper()
                : "U")
        </div>
        <div>
            <div class="sb-uname">
                @User.Identity?.Name
            </div>
            <div class="sb-urole">Customer</div>
        </div>
        @* Logout *@
        <a asp-controller="Account"
           asp-action="Logout"
           style="color:rgba(255,255,255,.25);
            font-size:12px;margin-left:auto"
           title="Logout">
            <i class="fa-solid fa-right-from-bracket"></i>
        </a>
    </div>
</div>
    </aside>
    <div class="main">
        <header class="hdr">
            <div class="hdr-ham" onclick="document.getElementById('sb').classList.toggle('open');document.getElementById('ov').classList.toggle('show')">
                <span></span><span></span><span></span>
            </div>
            <div class="hdr-crumb">
                <span>ShopNest</span>
                <i class="fa-solid fa-chevron-right" style="font-size:9px"></i>
                <span class="cp">My Dashboard</span>
            </div>
            <div class="hdr-srch"><i class="fa-solid fa-magnifying-glass"></i><input type="text" placeholder="Search products, orders, users…" /></div>
        <div class="hdr-acts">
            <div class="hdr-btn">
                <i class="fa-solid fa-bell"></i>
                <span class="ndot"></span>
            </div>
                @* Topbar mein Cart icon update karo *@
                <a asp-controller="Customer"
                   asp-action="Cart"
                   class="hdr-btn"
                   style="text-decoration:none;position:relative">
                    <i class="fa-solid fa-cart-shopping"></i>
                    @if (ViewBag.CartCount != null && ViewBag.CartCount > 0)
                    {
                        <span style="position:absolute;top:-5px;right:-5px;
                            background:var(--rose);color:#fff;
                            border-radius:50%;width:16px;height:16px;
                            font-size:10px;display:flex;align-items:center;
                            justify-content:center;font-weight:700">
                            @ViewBag.CartCount
                        </span>
                    }
                </a>

            <div class="hdr-btn">
                <i class="fa-solid fa-gear"></i>
            </div>

            @* Real User Profile *@
            <div class="hdr-prof">
                <div class="hdr-pav">
                    @(User.Identity?.Name?.Length > 1
                        ? User.Identity.Name.Substring(0, 2).ToUpper()
                        : "U")
                </div>
                <div>
                    <div class="hdr-pname">
                        @User.Identity?.Name
                    </div>
                    <div style="font-size:10px;color:var(--t3)">
                        Customer
                    </div>
                </div>
                <i class="fa-solid fa-chevron-down"
                   style="font-size:10px;color:var(--t3)"></i>
            </div>
        </div>
        </header>
        <div role="main">
            @RenderBody()
        </div>
    </div>



<script src="~/lib/jquery/dist/jquery.min.js"></script>

@* Bootstrap 5.3 CDN JS *@
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<script src="~/js/site.js" asp-append-version="true"></script>

@* Yeh add karo *@
@RenderSection("Scripts", required: false)
</body>
</html>
