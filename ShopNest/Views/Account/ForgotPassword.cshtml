@model ShopNest.Models.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot Password";
}

<div class="cnt page-anim">
    <div class="zpill gen">
        <i class="fa-solid fa-globe"></i> General Zone
    </div>

    <div style="max-width:420px;margin:0 auto">
        <div class="card-sn">
            <div class="ch justify-content-center flex-column align-items-center"
                 style="padding:24px 20px 16px">
                <div style="width:48px;height:48px;border-radius:12px;
                    background:linear-gradient(135deg,var(--blue),var(--cyan));
                    display:flex;align-items:center;
                    justify-content:center;font-size:20px;color:#fff;
                    margin-bottom:10px">
                    <i class="fa-solid fa-lock"></i>
                </div>
                <h3 style="font-size:18px">Forgot Password?</h3>
                <div style="font-size:12.5px;color:var(--t3);margin-top:2px;
                    text-align:center">
                    Enter your email — we'll send a reset link
                </div>
            </div>

            <div class="cb" style="padding-top:4px">

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger"
                         style="font-size:13px;border-radius:10px">
                        @TempData["Error"]
                    </div>
                }

                <form asp-controller="Account"
                      asp-action="ForgotPassword"
                      method="post">

                    @Html.AntiForgeryToken()

                    <div class="fgrp">
                        <label class="flbl">Email Address</label>
                        <input asp-for="Email"
                               class="finp"
                               placeholder="yourname@email.com" />
                        <span asp-validation-for="Email"
                              class="text-danger"
                              style="font-size:11px"></span>
                    </div>

                    <button type="submit"
                            class="btn-sn btn-p w-100 justify-content-center"
                            style="padding:12px">
                        <i class="fa-solid fa-paper-plane"></i>
                        Send Reset Link
                    </button>

                    <div class="text-center mt-3"
                         style="font-size:13px;color:var(--t3)">
                        Remember password?
                        <a asp-controller="Account"
                           asp-action="Login"
                           style="color:var(--blue);font-weight:700">
                            Sign In
                        </a>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>
