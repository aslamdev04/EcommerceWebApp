@model ShopNest.Models.ViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
}

<div class="cnt page-anim">
    <div class="zpill gen">
        <i class="fa-solid fa-globe"></i> General Zone
    </div>

    <div style="max-width:420px;margin:0 auto">
        <div class="card-sn">
            <div class="ch justify-content-center flex-column align-items-center"
                 style="padding:24px 20px 16px">
                <div style="width:48px;height:48px;border-radius:12px;
                    background:linear-gradient(135deg,var(--blue),var(--cyan));
                    display:flex;align-items:center;
                    justify-content:center;font-size:20px;
                    color:#fff;margin-bottom:10px">
                    <i class="fa-solid fa-key"></i>
                </div>
                <h3 style="font-size:18px">Set New Password</h3>
                <div style="font-size:12.5px;color:var(--t3);margin-top:2px">
                    Choose a strong new password
                </div>
            </div>

            <div class="cb" style="padding-top:4px">

                <form asp-controller="Account"
                      asp-action="ResetPassword"
                      method="post">

                    @Html.AntiForgeryToken()

                    @* Hidden token *@
                    <input asp-for="Token" type="hidden" />

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger"
                             style="font-size:13px;border-radius:10px">
                            @Html.ValidationSummary(false)
                        </div>
                    }

                    <div class="fgrp">
                        <label class="flbl">New Password</label>
                        <input asp-for="NewPassword"
                               type="password"
                               class="finp"
                               placeholder="Enter new password" />
                        <span asp-validation-for="NewPassword"
                              class="text-danger"
                              style="font-size:11px"></span>
                    </div>

                    <div class="fgrp">
                        <label class="flbl">Confirm Password</label>
                        <input asp-for="ConfirmPassword"
                               type="password"
                               class="finp"
                               placeholder="Repeat new password" />
                        <span asp-validation-for="ConfirmPassword"
                              class="text-danger"
                              style="font-size:11px"></span>
                    </div>

                    <button type="submit"
                            class="btn-sn btn-p w-100 justify-content-center"
                            style="padding:12px">
                        <i class="fa-solid fa-lock"></i>
                        Reset Password
                    </button>

                </form>
            </div>
        </div>
    </div>
</div>