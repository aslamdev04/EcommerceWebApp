@model ShopNest.Models.ViewModels.LoginViewModel;
@{
    ViewData["Title"] = "Login";
}

<div class="cnt page-anim">
    <div class="zpill gen"><i class="fa-solid fa-globe"></i> General Zone</div>
    <div style="max-width:420px;margin:0 auto">
        <div class="card-sn">
            <div class="ch justify-content-center flex-column align-items-center"
                 style="padding:24px 20px 16px">
                <div style="width:48px;height:48px;border-radius:12px;background:linear-gradient(135deg,var(--blue),var(--cyan));display:flex;align-items:center;justify-content:center;font-size:20px;color:#fff;margin-bottom:10px">
                    <i class="fa-solid fa-basket-shopping"></i>
                </div>
                <h3 style="font-size:18px;color:var(--t1)">Welcome Back!</h3>
                <div style="font-size:12.5px;color:var(--t3);margin-top:2px">
                    Sign in to your ShopNest account
                </div>
            </div>

            <div class="cb" style="padding-top:4px">

             
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger" style="font-size:13px">
                            @Html.ValidationSummary(false)
                        </div>
                    }

                    <form asp-controller="Account"
                          asp-action="Login"
                          method="post">

                        @Html.AntiForgeryToken()

                        <div class="fgrp">
                            <label class="flbl">Email Address</label>
                            <input asp-for="Email"
                                   class="finp"
                                   placeholder="yourname@email.com" />
                            <span asp-validation-for="Email"
                                  class="text-danger"
                                  style="font-size:11px"></span>
                        </div>

                        <div class="fgrp">
                            <label class="flbl">Password</label>
                            <input asp-for="Password"
                                   type="password"
                                   class="finp"
                                   placeholder="Enter your password" />
                            <span asp-validation-for="Password"
                                  class="text-danger"
                                  style="font-size:11px"></span>
                        </div>

                        <div class="d-flex justify-content-between
                            align-items-center mb-3">
                            <label class="d-flex align-items-center gap-2"
                                   style="font-size:12.5px;color:var(--t2);cursor:pointer">
                                <input type="checkbox" asp-for="RememberMe" />
                                Remember me
                            </label>
                            <span style="font-size:12.5px;color:var(--blue);
                                font-weight:600;cursor:pointer">
                                Forgot Password?
                            </span>
                        </div>

                        <button type="submit"
                                class="btn-sn btn-p w-100 justify-content-center"
                                style="padding:12px">
                            <i class="fa-solid fa-right-to-bracket"></i> Sign In
                        </button>

                        <div class="text-center" style="font-size:13px;color:var(--t3)">
                            New to ShopNest?
                            <a asp-controller="Account"
                               asp-action="Register"
                               style="color:var(--blue);font-weight:700">
                                Create Account
                            </a>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>