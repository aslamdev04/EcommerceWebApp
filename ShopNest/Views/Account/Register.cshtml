@model ShopNest.Models.ViewModels.RegisterViewModel;
@{
    ViewData["Title"] = "Register";
}

<div class="cnt page-anim">
    <div class="zpill gen">
        <i class="fa-solid fa-globe"></i> General Zone
    </div>
    <div style="max-width:480px;margin:0 auto">
        <div class="card-sn">
            <div class="ch justify-content-center flex-column align-items-center"
                 style="padding:24px 20px 16px">
                <div style="width:48px;height:48px;border-radius:12px;
                    background:linear-gradient(135deg,var(--blue),var(--cyan));
                    display:flex;align-items:center;justify-content:center;
                    font-size:20px;color:#fff;margin-bottom:10px">
                    <i class="fa-solid fa-basket-shopping"></i>
                </div>
                <h3 style="font-size:18px">Create Account</h3>
                <div style="font-size:12.5px;color:var(--t3);margin-top:2px">
                    Join ShopNest and start shopping
                </div>
            </div>

            <div class="cb" style="padding-top:4px">

                @* Validation Errors *@
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger" style="font-size:13px">
                        @Html.ValidationSummary(false)
                    </div>
                }

                <form asp-controller="Account"
                      asp-action="Register"
                      method="post">

                    @Html.AntiForgeryToken()

                    @* Full Name *@
                    <div class="fgrp">
                        <label class="flbl">Full Name</label>
                        <input asp-for="Name"
                               class="finp"
                               placeholder="Priya Sharma" />
                        <span asp-validation-for="Name"
                              class="text-danger"
                              style="font-size:11px"></span>
                    </div>

                    @* Email *@
                    <div class="fgrp">
                        <label class="flbl">Email Address</label>
                        <input asp-for="Email"
                               class="finp"
                               placeholder="yourname@email.com" />
                        <span asp-validation-for="Email"
                              class="text-danger"
                              style="font-size:11px"></span>
                    </div>

                    @* Password *@
                    <div class="fgrp">
                        <label class="flbl">Password</label>
                        <input asp-for="Password"
                               type="password"
                               class="finp"
                               placeholder="Create a strong password" />
                        <span asp-validation-for="Password"
                              class="text-danger"
                              style="font-size:11px"></span>
                    </div>

                    @* Confirm Password *@
                    <div class="fgrp">
                        <label class="flbl">Confirm Password</label>
                        <input asp-for="ConfirmPassword"
                               type="password"
                               class="finp"
                               placeholder="Repeat password" />
                        <span asp-validation-for="ConfirmPassword"
                              class="text-danger"
                              style="font-size:11px"></span>
                    </div>

                    @* Terms Checkbox *@
                    <div class="d-flex align-items-start gap-2 mb-3"
                         style="font-size:12.5px;color:var(--t2)">
                        <input type="checkbox"
                               style="margin-top:2px;flex-shrink:0"
                               required />
                        <span>
                            I agree to the
                            <a href="#" style="color:var(--blue);font-weight:600">
                                Terms of Service
                            </a> and
                            <a href="#" style="color:var(--blue);font-weight:600">
                                Privacy Policy
                            </a>
                        </span>
                    </div>

                    @* Submit Button *@
                    <button type="submit"
                            class="btn-sn btn-p w-100 justify-content-center"
                            style="padding:12px">
                        <i class="fa-solid fa-user-plus"></i> Create Account
                    </button>

                    @* Login Link *@
                    <div class="text-center mt-3"
                         style="font-size:13px;color:var(--t3)">
                        Already have an account?
                        <a asp-controller="Account"
                           asp-action="Login"
                           style="color:var(--blue);font-weight:700">Sign In</a>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>