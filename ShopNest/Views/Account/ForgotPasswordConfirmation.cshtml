@{
    ViewData["Title"] = "Check Your Email";
}

<div class="cnt page-anim">
    <div class="zpill gen">
        <i class="fa-solid fa-globe"></i> General Zone
    </div>

    <div style="max-width:420px;margin:0 auto;text-align:center">
        <div class="card-sn">
            <div class="cb" style="padding:40px">

                <div style="width:72px;height:72px;border-radius:50%;
                    background:linear-gradient(135deg,var(--blue),var(--cyan));
                    display:flex;align-items:center;
                    justify-content:center;font-size:28px;
                    color:#fff;margin:0 auto 20px">
                    <i class="fa-solid fa-envelope"></i>
                </div>

                <h3 style="font-size:18px;font-weight:800;margin-bottom:8px">
                    Check Your Email!
                </h3>

                <div style="font-size:13px;color:var(--t3);margin-bottom:24px">
                    @TempData["Info"]
                </div>

                @* Development Mode — Token Dikhao *@
                @if (TempData["ResetToken"] != null)
                {
                    <div style="background:var(--bg2);border-radius:10px;
                        padding:16px;margin-bottom:20px;
                        text-align:left">
                        <div style="font-size:11px;color:var(--t3);
                            margin-bottom:8px;font-weight:700">
                            🔧 DEVELOPMENT MODE — Reset Link:
                        </div>
                        <a asp-controller="Account"
                           asp-action="ResetPassword"
                           asp-route-token="@TempData["ResetToken"]"
                           style="color:var(--blue);font-size:12px;
                            word-break:break-all">
                            Click here to reset password →
                        </a>
                        <div style="font-size:11px;color:var(--t3);
                            margin-top:8px">
                            For: @TempData["ResetEmail"]
                            · Expires in 30 mins
                        </div>
                    </div>
                }

                <a asp-controller="Account"
                   asp-action="Login"
                   class="btn-sn btn-o w-100 justify-content-center">
                    <i class="fa-solid fa-arrow-left"></i>
                    Back to Login
                </a>

            </div>
        </div>
    </div>
</div>