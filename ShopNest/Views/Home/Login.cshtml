
@{
    ViewData["Title"] = "Login";
}

<div class="cnt page-anim">

    <div class="zpill gen"><i class="fa-solid fa-globe"></i> General Zone</div>
    <div style="max-width:420px;margin:0 auto">
        <div class="card-sn">
            <div class="ch justify-content-center flex-column align-items-center" style="padding:24px 20px 16px">
                <div style="width:48px;height:48px;border-radius:12px;background:linear-gradient(135deg,var(--blue),var(--cyan));display:flex;align-items:center;justify-content:center;font-size:20px;color:#fff;margin-bottom:10px"><i class="fa-solid fa-basket-shopping"></i></div>
                <h3 style="font-size:18px;color:var(--t1)">Welcome Back!</h3>
                <div style="font-size:12.5px;color:var(--t3);margin-top:2px">Sign in to your ShopNest account</div>
            </div>
            <div class="cb" style="padding-top:4px">
                <div class="d-flex gap-2 mb-3">
                    <a href="../admin/index.html" class="btn-sn btn-o btn-sm flex-fill justify-content-center" style="font-size:11px"><i class="fa-solid fa-shield-halved"></i> Admin</a>
                    <a href="../customer/index.html" class="btn-sn btn-o btn-sm flex-fill justify-content-center" style="font-size:11px"><i class="fa-solid fa-user"></i> Customer</a>
                </div>
                <div class="fgrp"><label class="flbl">Email Address</label><input type="email" class="finp" placeholder="yourname@email.com" /></div>
                <div class="fgrp"><label class="flbl">Password</label><input type="password" class="finp" placeholder="Enter your password" /></div>
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <label class="d-flex align-items-center gap-2" style="font-size:12.5px;color:var(--t2);cursor:pointer"><input type="checkbox" /> Remember me</label>
                    <span style="font-size:12.5px;color:var(--blue);font-weight:600;cursor:pointer">Forgot Password?</span>
                </div>
                <button class="btn-sn btn-p w-100 justify-content-center" style="padding:12px"><i class="fa-solid fa-right-to-bracket"></i> Sign In</button>
                <div class="text-center my-3 position-relative" style="font-size:12px;color:var(--t3)"><span style="background:#fff;padding:0 10px;position:relative;z-index:1">or continue with</span><div style="position:absolute;top:50%;left:0;right:0;height:1px;background:var(--bdr)"></div></div>
                <div class="d-flex gap-2 mb-3">
                    <button class="btn-sn btn-o flex-fill justify-content-center" style="font-size:12px"><i class="fa-brands fa-google" style="color:#ea4335"></i> Google</button>
                    <button class="btn-sn btn-o flex-fill justify-content-center" style="font-size:12px"><i class="fa-brands fa-facebook" style="color:#1877f2"></i> Facebook</button>
                </div>
                <div class="text-center" style="font-size:13px;color:var(--t3)">New to ShopNest? <a href="register.html" style="color:var(--blue);font-weight:700">Create Account</a></div>
            </div>
        </div>
    </div>
</div>

