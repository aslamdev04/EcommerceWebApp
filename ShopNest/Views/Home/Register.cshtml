
@{
    ViewData["Title"] = "Register";
}

<div class="cnt page-anim">

    <div class="zpill gen"><i class="fa-solid fa-globe"></i> General Zone</div>
    <div style="max-width:480px;margin:0 auto">
        <div class="card-sn">
            <div class="ch justify-content-center flex-column align-items-center" style="padding:24px 20px 16px">
                <div style="width:48px;height:48px;border-radius:12px;background:linear-gradient(135deg,var(--blue),var(--cyan));display:flex;align-items:center;justify-content:center;font-size:20px;color:#fff;margin-bottom:10px"><i class="fa-solid fa-basket-shopping"></i></div>
                <h3 style="font-size:18px">Create Account</h3>
                <div style="font-size:12.5px;color:var(--t3);margin-top:2px">Join ShopNest and start shopping</div>
            </div>
            <div class="cb" style="padding-top:4px">
                <div class="row g-3 mb-3"><div class="col-6"><label class="flbl">First Name</label><input type="text" class="finp" placeholder="Priya" /></div><div class="col-6"><label class="flbl">Last Name</label><input type="text" class="finp" placeholder="Sharma" /></div></div>
                <div class="fgrp"><label class="flbl">Email Address</label><input type="email" class="finp" placeholder="yourname@email.com" /></div>
                <div class="fgrp"><label class="flbl">Phone Number</label><input type="tel" class="finp" placeholder="98765 43210" /></div>
                <div class="fgrp"><label class="flbl">Password</label><input type="password" class="finp" placeholder="Create a strong password" /></div>
                <div class="fgrp"><label class="flbl">Confirm Password</label><input type="password" class="finp" placeholder="Repeat password" /></div>
                <div class="d-flex align-items-start gap-2 mb-3" style="font-size:12.5px;color:var(--t2)">
                    <input type="checkbox" style="margin-top:2px;flex-shrink:0" />
                    <span>I agree to the <a href="#" style="color:var(--blue);font-weight:600">Terms of Service</a> and <a href="#" style="color:var(--blue);font-weight:600">Privacy Policy</a></span>
                </div>
                <button class="btn-sn btn-p w-100 justify-content-center" style="padding:12px"><i class="fa-solid fa-user-plus"></i> Create Account</button>
                <div class="text-center mt-3" style="font-size:13px;color:var(--t3)">Already have an account? <a href="login.html" style="color:var(--blue);font-weight:700">Sign In</a></div>
            </div>
        </div>
    </div>
</div>

