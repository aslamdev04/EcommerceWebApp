
@{
    ViewData["Title"] = "Contacts";
}


<div class="cnt page-anim">

    <div class="zpill gen"><i class="fa-solid fa-globe"></i> General Zone</div>
    <div class="ph"><div><h1>Contact &amp; Support</h1><p>We're here to help you 24/7.</p></div></div>
    <div class="g2">
        <div class="card-sn">
            <div class="ch"><h3><i class="fa-solid fa-headset"></i> Send a Message</h3></div>
            <div class="cb d-flex flex-column gap-3">
                <div><label class="flbl">Your Name</label><input type="text" class="finp" placeholder="Full name" /></div>
                <div><label class="flbl">Email</label><input type="email" class="finp" placeholder="your@email.com" /></div>
                <div><label class="flbl">Subject</label><select class="tsel w-100"><option>Order Issue</option><option>Payment Problem</option><option>Product Query</option><option>Return/Refund</option><option>Other</option></select></div>
                <div><label class="flbl">Order ID (if applicable)</label><input type="text" class="finp" placeholder="#ORD-XXXX" /></div>
                <div><label class="flbl">Message</label><textarea rows="4" class="finp" style="resize:vertical" placeholder="Describe your issue in detail…"></textarea></div>
                <button class="btn-sn btn-p justify-content-center"><i class="fa-solid fa-paper-plane"></i> Send Message</button>
            </div>
        </div>
        <div class="d-flex flex-column gap-3">
            <div class="card-sn">
                <div class="ch"><h3><i class="fa-solid fa-phone"></i> Contact Channels</h3></div>
                <div class="cb d-flex flex-column gap-3">
                    <div class="d-flex gap-3 align-items-center"><div style="width:40px;height:40px;border-radius:10px;background:var(--blue-l);display:flex;align-items:center;justify-content:center;font-size:16px;color:var(--blue)"><i class="fa-solid fa-phone"></i></div><div><div style="font-size:13.5px;font-weight:700">Phone Support</div><div style="font-size:12.5px;color:var(--t3)">1800-123-4567 · 24/7</div></div></div>
                    <div class="d-flex gap-3 align-items-center"><div style="width:40px;height:40px;border-radius:10px;background:#d1fae5;display:flex;align-items:center;justify-content:center;font-size:16px;color:var(--emerald)"><i class="fa-brands fa-whatsapp"></i></div><div><div style="font-size:13.5px;font-weight:700">WhatsApp</div><div style="font-size:12.5px;color:var(--t3)">+91 98765 00000</div></div></div>
                    <div class="d-flex gap-3 align-items-center"><div style="width:40px;height:40px;border-radius:10px;background:#fef3c7;display:flex;align-items:center;justify-content:center;font-size:16px;color:var(--amber)"><i class="fa-solid fa-envelope"></i></div><div><div style="font-size:13.5px;font-weight:700">Email</div><div style="font-size:12.5px;color:var(--t3)">support@shopnest.in</div></div></div>
                    <div class="d-flex gap-3 align-items-center"><div style="width:40px;height:40px;border-radius:10px;background:#ede9fe;display:flex;align-items:center;justify-content:center;font-size:16px;color:var(--violet)"><i class="fa-solid fa-comments"></i></div><div><div style="font-size:13.5px;font-weight:700">Live Chat</div><div style="font-size:12.5px;color:var(--t3)">Available 8 AM – 10 PM</div></div></div>
                </div>
            </div>
            <div class="card-sn">
                <div class="ch"><h3><i class="fa-solid fa-circle-question"></i> Quick Help</h3></div>
                <div class="cb d-flex flex-column gap-2">
                    <button class="btn-sn btn-o justify-content-start" style="font-size:12.5px"><i class="fa-solid fa-box"></i> Track my Order</button>
                    <button class="btn-sn btn-o justify-content-start" style="font-size:12.5px"><i class="fa-solid fa-rotate-left"></i> Return Policy</button>
                    <button class="btn-sn btn-o justify-content-start" style="font-size:12.5px"><i class="fa-solid fa-credit-card"></i> Payment Issues</button>
                    <button class="btn-sn btn-o justify-content-start" style="font-size:12.5px"><i class="fa-solid fa-star"></i> Cancellation</button>
                </div>
            </div>
        </div>
    </div>
</div>

