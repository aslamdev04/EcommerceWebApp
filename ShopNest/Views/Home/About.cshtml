
@{
    ViewData["Title"] = "About";
}

<div class="cnt page-anim">

    <div class="zpill gen"><i class="fa-solid fa-globe"></i> General Zone</div>
    <div class="ph"><div><h1>About ShopNest</h1><p>India's fastest-growing e-commerce platform.</p></div></div>
    <div class="hero mb-18">
        <h2>🛍️ Our Story</h2>
        <p>Founded in 2022, ShopNest was built with a simple vision: to make quality shopping accessible to every Indian household. Today, we serve over 18,000 customers across 500+ cities with 4,000+ products.</p>
        <div class="d-flex gap-3 mt-4 flex-wrap">
            <div style="background:rgba(255,255,255,.1);border:1.5px solid rgba(255,255,255,.2);padding:14px 20px;border-radius:10px;text-align:center"><div style="font-size:22px;font-weight:800;font-family:var(--mono)">18K+</div><div style="font-size:11px;opacity:.7;margin-top:2px">Happy Customers</div></div>
            <div style="background:rgba(255,255,255,.1);border:1.5px solid rgba(255,255,255,.2);padding:14px 20px;border-radius:10px;text-align:center"><div style="font-size:22px;font-weight:800;font-family:var(--mono)">4.2K+</div><div style="font-size:11px;opacity:.7;margin-top:2px">Products</div></div>
            <div style="background:rgba(255,255,255,.1);border:1.5px solid rgba(255,255,255,.2);padding:14px 20px;border-radius:10px;text-align:center"><div style="font-size:22px;font-weight:800;font-family:var(--mono)">500+</div><div style="font-size:11px;opacity:.7;margin-top:2px">Cities Served</div></div>
            <div style="background:rgba(255,255,255,.1);border:1.5px solid rgba(255,255,255,.2);padding:14px 20px;border-radius:10px;text-align:center"><div style="font-size:22px;font-weight:800;font-family:var(--mono)">4.7★</div><div style="font-size:11px;opacity:.7;margin-top:2px">Avg. Rating</div></div>
        </div>
    </div>
    <div class="g2">
        <div class="card-sn"><div class="ch"><h3><i class="fa-solid fa-bullseye"></i> Our Mission</h3></div><div class="cb" style="font-size:13.5px;color:var(--t2);line-height:1.6">To democratize e-commerce in India by providing a seamless, trustworthy, and delightful shopping experience for every customer — from metros to tier-3 cities. We believe in fair pricing, quality products, and exceptional service.</div></div>
        <div class="card-sn"><div class="ch"><h3><i class="fa-solid fa-eye"></i> Our Vision</h3></div><div class="cb" style="font-size:13.5px;color:var(--t2);line-height:1.6">To become India's most trusted e-commerce platform by 2030, serving 10 million customers with zero-compromise quality standards, lightning-fast delivery, and an unmatched return experience.</div></div>
    </div>
</div>

