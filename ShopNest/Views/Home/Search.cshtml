@model List<ShopNest.Models.ViewModels.ProductBrowseViewModel>
@{
    ViewData["Title"] = "Search";
    string query = ViewBag.Query ?? "";
}

<div class="cnt page-anim">

    <div class="zpill gen">
        <i class="fa-solid fa-globe"></i> General Zone
    </div>

    <div class="ph">
        <div><h1>Search Products</h1></div>
    </div>

    @* ── Search Bar ── *@
    <div class="card-sn mb-18">
        <div class="cb">
            <form asp-controller="Home"
                  asp-action="Search"
                  method="get">
                <div class="d-flex gap-2 flex-wrap">
                    <div style="flex:2;min-width:200px;position:relative">
                        <i class="fa-solid fa-magnifying-glass"
                           style="position:absolute;left:12px;top:50%;
                        transform:translateY(-50%);
                        color:var(--t3)"></i>
                        <input type="text"
                               name="q"
                               class="finp"
                               style="padding-left:36px"
                               placeholder="Search products…"
                               value="@query" />
                    </div>
                    <button type="submit" class="btn-sn btn-p">
                        <i class="fa-solid fa-magnifying-glass"></i>
                        Search
                    </button>
                </div>
            </form>

            @if (!string.IsNullOrEmpty(query))
            {
                <div class="mt-3"
                     style="font-size:13px;color:var(--t3)">
                    Showing results for
                    <strong style="color:var(--t1)">"@query"</strong>
                    — @ViewBag.ResultCount products found
                </div>
            }
        </div>
    </div>

    @* ── Results ── *@
    @if (!Model.Any() && !string.IsNullOrEmpty(query))
    {
        <div class="text-center" style="padding:60px;color:var(--t3)">
            <i class="fa-solid fa-search"
               style="font-size:48px;margin-bottom:16px"></i>
            <div style="font-size:16px;font-weight:600">
                No results for "@query"
            </div>
            <div style="font-size:13px;margin-top:4px">
                Try different keywords
            </div>
        </div>
    }
    else if (Model.Any())
    {
        <div class="pgrid">
            @foreach (var p in Model)
            {
                <div class="pcard">
                    <div class="pcard-img">
                        @if (p.ImageUrl != null &&
                             p.ImageUrl != "/images/default.png")
                        {
                            <img src="@p.ImageUrl"
                                 style="width:100%;height:100%;
                            object-fit:cover" />
                        }
                        else
                        {
                            @p.CategoryIcon
                        }
                    </div>
                    <div class="pcard-body">
                        <div class="pcard-name">@p.Name</div>
                        <div class="pcard-cat">
                            @p.CategoryIcon @p.CategoryName
                        </div>
                        <div class="pcard-foot">
                            <div>
                                <span class="pcard-price">
                                    ₹@p.Price?.ToString("N0")
                                </span>
                            </div>
                            <a asp-controller="Account"
                               asp-action="Login"
                               class="pcard-addcart">
                                Add Cart
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center" style="padding:60px;color:var(--t3)">
            <i class="fa-solid fa-search" style="font-size:48px"></i>
            <div style="margin-top:8px">
                Type something to search products
            </div>
        </div>
    }

</div>