
@{
    ViewData["Title"] = "Search";
}

<div class="cnt page-anim">

    <div class="zpill gen"><i class="fa-solid fa-globe"></i> General Zone</div>
    <div class="ph"><div><h1>Search Products</h1></div></div>
    <div class="card-sn mb-18">
        <div class="cb">
            <div class="d-flex gap-2 flex-wrap">
                <div style="flex:2;min-width:200px;position:relative"><i class="fa-solid fa-magnifying-glass" style="position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--t3)"></i><input type="text" class="finp" style="padding-left:36px" placeholder="Search products…" value="iPhone" /></div>
                <select class="tsel"><option>All Categories</option><option>Electronics</option><option>Fashion</option></select>
                <select class="tsel"><option>Sort: Relevance</option><option>Price: Low–High</option><option>Rating</option></select>
                <button class="btn-sn btn-p"><i class="fa-solid fa-magnifying-glass"></i> Search</button>
            </div>
            <div class="mt-3" style="font-size:13px;color:var(--t3)">Showing results for <strong style="color:var(--t1)">"iPhone"</strong> — 12 products found</div>
        </div>
    </div>
    <div class="pgrid">
        <div class="pcard"><div class="pcard-img">📱<span class="pcard-badge sale">SALE</span></div><div class="pcard-body"><div class="pcard-name">iPhone 15 Pro Max</div><div class="pcard-cat">Electronics · Apple · ⭐ 4.8</div><div class="pcard-foot"><div><span class="pcard-price">₹1,24,900</span><span class="pcard-oldprice">₹1,29,900</span></div><a href="login.html" class="pcard-addcart">Add Cart</a></div></div></div>
        <div class="pcard"><div class="pcard-img" style="background:linear-gradient(135deg,#dbeafe,#bfdbfe)">📱</div><div class="pcard-body"><div class="pcard-name">iPhone 15 Standard</div><div class="pcard-cat">Electronics · Apple · ⭐ 4.6</div><div class="pcard-foot"><span class="pcard-price">₹79,900</span><a href="login.html" class="pcard-addcart">Add Cart</a></div></div></div>
        <div class="pcard"><div class="pcard-img" style="background:linear-gradient(135deg,#f0fdf4,#dcfce7)">📱</div><div class="pcard-body"><div class="pcard-name">iPhone 14 Pro</div><div class="pcard-cat">Electronics · Apple · ⭐ 4.7</div><div class="pcard-foot"><span class="pcard-price">₹99,900</span><a href="login.html" class="pcard-addcart">Add Cart</a></div></div></div>
    </div>
</div>

