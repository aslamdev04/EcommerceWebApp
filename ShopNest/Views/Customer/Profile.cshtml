
@{
    ViewData["Title"] = "Profile";
    Layout = "~/Views/Shared/_Customer.cshtml";
}

<div class="cnt page-anim">

    <div class="zpill cus"><i class="fa-solid fa-user-circle"></i> Customer Zone</div>
    <div class="ph"><div><h1>My Profile</h1><p>Manage your personal information and preferences.</p></div><div class="ph-acts"><button class="btn-sn btn-p"><i class="fa-solid fa-floppy-disk"></i> Save Changes</button></div></div>
    <div class="g3r">
        <div class="d-flex flex-column gap-3">
            <div class="card-sn">
                <div class="cb text-center">
                    <div style="width:72px;height:72px;border-radius:50%;background:linear-gradient(135deg,var(--blue),var(--cyan));margin:0 auto 12px;display:flex;align-items:center;justify-content:center;font-size:26px;font-weight:800;color:#fff">PS</div>
                    <div style="font-size:16px;font-weight:800">Priya Sharma</div>
                    <div style="font-size:12.5px;color:var(--t3)">priya@gmail.com</div>
                    <div class="d-flex justify-content-around mt-3 pt-3" style="border-top:1px solid var(--bdr)">
                        <div><div style="font-size:16px;font-weight:800;font-family:var(--mono)">14</div><div style="font-size:11px;color:var(--t3)">Orders</div></div>
                        <div><div style="font-size:16px;font-weight:800;font-family:var(--mono)">24</div><div style="font-size:11px;color:var(--t3)">Wishlist</div></div>
                        <div><div style="font-size:16px;font-weight:800;font-family:var(--mono)">₹28K</div><div style="font-size:11px;color:var(--t3)">Spent</div></div>
                    </div>
                </div>
            </div>
            <div class="card-sn">
                <div class="ch"><h3><i class="fa-solid fa-shield-halved"></i> Account Security</h3></div>
                <div class="cb d-flex flex-column gap-2">
                    <button class="btn-sn btn-o justify-content-start"><i class="fa-solid fa-lock"></i> Change Password</button>
                    <button class="btn-sn btn-o justify-content-start"><i class="fa-solid fa-mobile-screen"></i> Enable 2FA</button>
                    <button class="btn-sn btn-o justify-content-start" style="border-color:var(--rose);color:var(--rose)"><i class="fa-solid fa-trash"></i> Delete Account</button>
                </div>
            </div>
        </div>
        <div class="card-sn">
            <div class="ch"><h3><i class="fa-solid fa-pen-to-square"></i> Edit Profile</h3></div>
            <div class="cb">
                <div class="row g-3 mb-3"><div class="col-6"><label class="flbl">First Name</label><input type="text" class="finp" value="Priya" /></div><div class="col-6"><label class="flbl">Last Name</label><input type="text" class="finp" value="Sharma" /></div></div>
                <div class="fgrp"><label class="flbl">Email Address</label><input type="email" class="finp" value="priya@gmail.com" /></div>
                <div class="fgrp"><label class="flbl">Phone Number</label><input type="tel" class="finp" value="98765 43210" /></div>
                <div class="fgrp"><label class="flbl">Date of Birth</label><input type="date" class="finp" /></div>
                <div class="fgrp"><label class="flbl">Gender</label><select class="tsel w-100"><option>Female</option><option>Male</option><option>Other</option></select></div>
                <div class="fgrp"><label class="flbl">Default Address</label><textarea rows="3" class="finp" style="resize:vertical">Flat 4B, Sunflower Apartments, Andheri West, Mumbai — 400058</textarea></div>
            </div>
        </div>
    </div>
</div>

