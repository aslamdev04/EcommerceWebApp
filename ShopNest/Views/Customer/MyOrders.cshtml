
@{
    ViewData["Title"] = "MyOrders";
    Layout = "~/Views/Shared/_Customer.cshtml";
}

<div class="cnt page-anim">

    <div class="zpill cus"><i class="fa-solid fa-user-circle"></i> Customer Zone</div>
    <div class="ph"><div><h1>My Orders</h1><p>View and manage all your orders.</p></div></div>
    <div class="card-sn">
        <div class="tabr"><button class="tabb on">All (14)</button><button class="tabb">Processing</button><button class="tabb">Shipped</button><button class="tabb">Delivered</button><button class="tabb">Cancelled</button></div>
        <div class="tf"><div class="ts"><i class="fa-solid fa-magnifying-glass"></i><input type="text" placeholder="Search orders…" /></div></div>
        <div class="table-responsive">
            <table class="dt">
                <thead><tr><th>Order ID</th><th>Products</th><th>Date</th><th>Amount</th><th>Status</th><th>Actions</th></tr></thead>
                <tbody>
                    <tr><td style="font-family:var(--mono);color:var(--blue);font-weight:700">#ORD-8821</td><td>📱 iPhone 15 Pro + 2 more</td><td>Mar 16, 2026</td><td><span style="font-family:var(--mono);font-weight:700">₹18,450</span></td><td><span class="bdg bdg-delivered">Delivered</span></td><td><div class="d-flex gap-1"><a href="order-track.html" class="btn-sn btn-o btn-xs"><i class="fa-solid fa-eye"></i> View</a><button class="btn-sn btn-o btn-xs"><i class="fa-solid fa-rotate-left"></i> Return</button></div></td></tr>
                    <tr><td style="font-family:var(--mono);color:var(--blue);font-weight:700">#ORD-8814</td><td>👟 Nike Air Max + 4 more</td><td>Mar 14, 2026</td><td><span style="font-family:var(--mono);font-weight:700">₹7,230</span></td><td><span class="bdg bdg-shipped">Shipped</span></td><td><div class="d-flex gap-1"><a href="order-track.html" class="btn-sn btn-o btn-xs"><i class="fa-solid fa-route"></i> Track</a><button class="btn-sn btn-o btn-xs" style="border-color:var(--rose);color:var(--rose)"><i class="fa-solid fa-xmark"></i> Cancel</button></div></td></tr>
                    <tr><td style="font-family:var(--mono);color:var(--blue);font-weight:700">#ORD-8801</td><td>🛋️ L-Shape Sofa Set</td><td>Mar 12, 2026</td><td><span style="font-family:var(--mono);font-weight:700">₹42,000</span></td><td><span class="bdg bdg-processing">Processing</span></td><td><div class="d-flex gap-1"><button class="btn-sn btn-o btn-xs"><i class="fa-solid fa-eye"></i> View</button></div></td></tr>
                </tbody>
            </table>
        </div>
        <div class="pgn"><div class="pgn-info">Showing 1–3 of 14 orders</div><div class="pgn-btns"><button class="pb on">1</button><button class="pb">2</button><button class="pb">3</button></div></div>
    </div>
</div>

