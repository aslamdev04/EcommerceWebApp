
@{
    ViewData["Title"] = "CheckOut";
    Layout = "~/Views/Shared/_Customer.cshtml";
}

<div class="cnt page-anim">

    <div class="zpill cus"><i class="fa-solid fa-user-circle"></i> Customer Zone</div>
    <div class="ph"><div><h1>Checkout</h1><p>Review your order and enter delivery details.</p></div></div>
    <div class="g3r">
        <div>
            <div class="card-sn mb-18">
                <div class="ch"><h3><i class="fa-solid fa-location-dot"></i> Delivery Address</h3><button class="btn-sn btn-o btn-sm">+ Add New</button></div>
                <div class="cb">
                    <div style="border:2px solid var(--blue);border-radius:9px;padding:14px;background:var(--blue-l)">
                        <div style="font-size:13px;font-weight:700">Priya Sharma <span class="bdg bdg-active" style="margin-left:6px">Default</span></div>
                        <div style="font-size:12.5px;color:var(--t2);margin-top:4px">Flat 4B, Sunflower Apartments, Andheri West<br />Mumbai — 400058, Maharashtra, India<br />Phone: 98765 43210</div>
                    </div>
                    <div style="border:1.5px solid var(--bdr);border-radius:9px;padding:14px;margin-top:10px;cursor:pointer">
                        <div style="font-size:13px;font-weight:700">Work Address</div>
                        <div style="font-size:12.5px;color:var(--t2);margin-top:4px">Tech Park, Powai, Mumbai — 400076, MH</div>
                    </div>
                </div>
            </div>
            <div class="card-sn">
                <div class="ch"><h3><i class="fa-solid fa-truck"></i> Delivery Options</h3></div>
                <div class="cb d-flex flex-column gap-2">
                    <label style="display:flex;align-items:center;gap:12px;padding:12px;border:2px solid var(--blue);border-radius:9px;background:var(--blue-l);cursor:pointer"><input type="radio" name="del" checked /><div><div style="font-size:13px;font-weight:700">Standard Delivery</div><div style="font-size:12px;color:var(--t3)">3–5 business days · FREE</div></div></label>
                    <label style="display:flex;align-items:center;gap:12px;padding:12px;border:1.5px solid var(--bdr);border-radius:9px;cursor:pointer"><input type="radio" name="del" /><div><div style="font-size:13px;font-weight:700">Express Delivery</div><div style="font-size:12px;color:var(--t3)">1–2 business days · ₹149</div></div></label>
                    <label style="display:flex;align-items:center;gap:12px;padding:12px;border:1.5px solid var(--bdr);border-radius:9px;cursor:pointer"><input type="radio" name="del" /><div><div style="font-size:13px;font-weight:700">Same Day Delivery</div><div style="font-size:12px;color:var(--t3)">Today by 9 PM · ₹299</div></div></label>
                </div>
            </div>
        </div>
        <div class="card-sn">
            <div class="ch"><h3><i class="fa-solid fa-receipt"></i> Order Review</h3></div>
            <div class="cb">
                <div class="d-flex flex-column gap-2 mb-3">
                    <div class="d-flex align-items-center gap-2"><div style="width:40px;height:40px;border-radius:8px;background:var(--blue-l);display:flex;align-items:center;justify-content:center;font-size:18px">📱</div><div style="flex:1"><div style="font-size:12.5px;font-weight:700">iPhone 15 Pro Max</div><div style="font-size:11.5px;color:var(--t3)">Qty: 1</div></div><div style="font-family:var(--mono);font-weight:700;font-size:13px">₹1,24,900</div></div>
                    <div class="d-flex align-items-center gap-2"><div style="width:40px;height:40px;border-radius:8px;background:#d1fae5;display:flex;align-items:center;justify-content:center;font-size:18px">👟</div><div style="flex:1"><div style="font-size:12.5px;font-weight:700">Nike Air Max 270</div><div style="font-size:11.5px;color:var(--t3)">Qty: 2</div></div><div style="font-family:var(--mono);font-weight:700;font-size:13px">₹25,990</div></div>
                    <div class="d-flex align-items-center gap-2"><div style="width:40px;height:40px;border-radius:8px;background:#fef3c7;display:flex;align-items:center;justify-content:center;font-size:18px">⌚</div><div style="flex:1"><div style="font-size:12.5px;font-weight:700">Apple Watch Series 9</div><div style="font-size:11.5px;color:var(--t3)">Qty: 1</div></div><div style="font-family:var(--mono);font-weight:700;font-size:13px">₹41,900</div></div>
                </div>
                <div class="order-sum">
                    <div class="os-row"><span>Subtotal</span><span>₹1,92,790</span></div>
                    <div class="os-row"><span>Discount</span><span style="color:var(--emerald)">-₹48,197</span></div>
                    <div class="os-row"><span>Delivery</span><span style="color:var(--emerald)">FREE</span></div>
                    <div class="os-row"><span>GST</span><span>₹25,994</span></div>
                    <div class="os-row" style="padding-top:10px;border-top:2px solid var(--bdr)"><span>Total</span><span style="color:var(--blue)">₹1,70,587</span></div>
                </div>
                <a href="payment.html" class="btn-sn btn-p w-100 justify-content-center mt-3"><i class="fa-solid fa-credit-card"></i> Proceed to Payment</a>
            </div>
        </div>
    </div>
</div>

