@model ShopNest.Models.ViewModels.CheckoutViewModel
@{
    ViewData["Title"] = "Checkout";
    Layout = "~/Views/Shared/_Customer.cshtml";
}

<div class="cnt page-anim">

    <div class="zpill cus">
        <i class="fa-solid fa-user-circle"></i> Customer Zone
    </div>

    <div class="ph">
        <div>
            <h1>Checkout</h1>
            <p>Review your order and enter delivery details.</p>
        </div>
    </div>

    <form asp-controller="Customer"
          asp-action="PlaceOrder"
          method="post">

        @Html.AntiForgeryToken()

        <div class="g3r">

            @* ── Left Side ── *@
            <div>

                @* Delivery Address *@
                <div class="card-sn mb-18">
                    <div class="ch">
                        <h3>
                            <i class="fa-solid fa-location-dot"></i>
                            Delivery Address
                        </h3>
                    </div>
                    <div class="cb">

                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger"
                                 style="font-size:13px;border-radius:10px">
                                @Html.ValidationSummary(false)
                            </div>
                        }

                        <div class="row g-3">
                            <div class="col-12">
                                <label class="flbl">Full Address</label>
                                <input asp-for="Address"
                                       class="finp"
                                       placeholder="Flat/House No, Street, Area" />
                                <span asp-validation-for="Address"
                                      class="text-danger"
                                      style="font-size:11px"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="flbl">City</label>
                                <input asp-for="City"
                                       class="finp"
                                       placeholder="Mumbai" />
                                <span asp-validation-for="City"
                                      class="text-danger"
                                      style="font-size:11px"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="flbl">Pincode</label>
                                <input asp-for="Pincode"
                                       class="finp"
                                       placeholder="400058" />
                                <span asp-validation-for="Pincode"
                                      class="text-danger"
                                      style="font-size:11px"></span>
                            </div>
                            <div class="col-12">
                                <label class="flbl">Phone Number</label>
                                <input asp-for="Phone"
                                       class="finp"
                                       placeholder="98765 43210" />
                                <span asp-validation-for="Phone"
                                      class="text-danger"
                                      style="font-size:11px"></span>
                            </div>
                        </div>

                    </div>
                </div>

                @* Delivery Options *@
                <div class="card-sn">
                    <div class="ch">
                        <h3><i class="fa-solid fa-truck"></i> Delivery Options</h3>
                    </div>
                    <div class="cb d-flex flex-column gap-2">

                        <label style="display:flex;align-items:center;gap:12px;
                            padding:12px;border:2px solid var(--blue);
                            border-radius:9px;background:var(--blue-l);
                            cursor:pointer">
                            <input type="radio"
                                   asp-for="DeliveryOption"
                                   value="Standard"
                                   checked />
                            <div>
                                <div style="font-size:13px;font-weight:700">
                                    Standard Delivery
                                </div>
                                <div style="font-size:12px;color:var(--t3)">
                                    3–5 business days · FREE
                                </div>
                            </div>
                        </label>

                        <label style="display:flex;align-items:center;gap:12px;
                            padding:12px;border:1.5px solid var(--bdr);
                            border-radius:9px;cursor:pointer">
                            <input type="radio"
                                   asp-for="DeliveryOption"
                                   value="Express" />
                            <div>
                                <div style="font-size:13px;font-weight:700">
                                    Express Delivery
                                </div>
                                <div style="font-size:12px;color:var(--t3)">
                                    1–2 business days · ₹149
                                </div>
                            </div>
                        </label>

                        <label style="display:flex;align-items:center;gap:12px;
                            padding:12px;border:1.5px solid var(--bdr);
                            border-radius:9px;cursor:pointer">
                            <input type="radio"
                                   asp-for="DeliveryOption"
                                   value="SameDay" />
                            <div>
                                <div style="font-size:13px;font-weight:700">
                                    Same Day Delivery
                                </div>
                                <div style="font-size:12px;color:var(--t3)">
                                    Today by 9 PM · ₹299
                                </div>
                            </div>
                        </label>

                    </div>
                </div>
            </div>

            @* ── Right Side — Order Review ── *@
            <div class="card-sn">
                <div class="ch">
                    <h3><i class="fa-solid fa-receipt"></i> Order Review</h3>
                </div>
                <div class="cb">

                    @* Items List *@
                    <div class="d-flex flex-column gap-2 mb-3">
                        @foreach (var item in Model.Items)
                        {
                            <div class="d-flex align-items-center gap-2">
                                <div style="width:40px;height:40px;border-radius:8px;
                                    background:var(--blue-l);display:flex;
                                    align-items:center;justify-content:center;
                                    font-size:18px">
                                    @item.CategoryIcon
                                </div>
                                <div style="flex:1">
                                    <div style="font-size:12.5px;font-weight:700">
                                        @item.ProductName
                                    </div>
                                    <div style="font-size:11.5px;color:var(--t3)">
                                        Qty: @item.Quantity
                                    </div>
                                </div>
                                <div style="font-family:var(--mono);
                                    font-weight:700;font-size:13px">
                                    ₹@item.TotalPrice.ToString("N0")
                                </div>
                            </div>
                        }
                    </div>

                    @* Order Summary *@
                    <div class="order-sum">
                        <div class="os-row">
                            <span>Subtotal (@Model.TotalItems items)</span>
                            <span>₹@Model.Subtotal.ToString("N0")</span>
                        </div>
                        <div class="os-row">
                            <span>Delivery</span>
                            @if (Model.DeliveryCharge == 0)
                            {
                                <span style="color:var(--emerald)">FREE</span>
                            }
                            else
                            {
                                <span>₹@Model.DeliveryCharge</span>
                            }
                        </div>
                        <div class="os-row">
                            <span>GST (18%)</span>
                            <span>₹@Model.GST.ToString("N0")</span>
                        </div>
                        <div class="os-row"
                             style="padding-top:10px;
                            border-top:2px solid var(--bdr)">
                            <span>Total</span>
                            <span style="color:var(--blue);font-weight:700">
                                ₹@Model.Total.ToString("N0")
                            </span>
                        </div>
                    </div>

                    @* Place Order Button *@
                    <button type="submit"
                            class="btn-sn btn-p w-100 justify-content-center mt-3">
                        <i class="fa-solid fa-bag-shopping"></i>
                        Place Order
                    </button>

                    @* Back to Cart *@
                    <a asp-controller="Customer"
                       asp-action="Cart"
                       class="btn-sn btn-o w-100 justify-content-center mt-2">
                        <i class="fa-solid fa-arrow-left"></i>
                        Back to Cart
                    </a>

                </div>
            </div>

        </div>
    </form>
</div>