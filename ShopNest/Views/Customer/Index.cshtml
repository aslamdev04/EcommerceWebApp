@model ShopNest.Models.ViewModels.CustomerDashboardViewModel
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Customer.cshtml";
}

<div class="cnt page-anim">

    <div class="zpill cus">
        <i class="fa-solid fa-user-circle"></i> Customer Zone
    </div>

    <div class="ph">
        <div>
            <h1>My Dashboard</h1>
            <p>Track your orders, wishlist, and account activity.</p>
        </div>
        <div class="ph-acts">
            <a asp-controller="Customer"
               asp-action="Browse"
               class="btn-sn btn-p">
                <i class="fa-solid fa-shop"></i> Shop Now
            </a>
        </div>
    </div>

    @* ── Welcome Banner ── *@
    <div style="background:linear-gradient(135deg,var(--ink),var(--ink2),#1e3a5f);
        border-radius:var(--r);padding:28px;color:#fff;margin-bottom:22px;
        display:flex;align-items:center;justify-content:space-between;
        flex-wrap:wrap;gap:14px;position:relative;overflow:hidden">
        <div style="position:absolute;top:-40px;right:-40px;width:160px;height:160px;
        border-radius:50%;background:rgba(37,99,235,.2)"></div>
        <div>
            <div style="font-size:11px;font-weight:700;letter-spacing:.6px;
                text-transform:uppercase;opacity:.6;margin-bottom:6px">
                Welcome Back
            </div>
            <div style="font-size:20px;font-weight:800">
                Hello, @Model.UserName! 👋   @* ← Real Name *@
            </div>
            <div style="font-size:13px;opacity:.7;margin-top:4px">
                You have @Model.InTransitOrders orders in transit.
            </div>
        </div>
        <div class="d-flex gap-4 flex-wrap">
            <div style="text-align:center">
                <div style="font-size:26px;font-weight:800;font-family:var(--mono)">
                    @Model.TotalOrders   @* ← Real Orders *@
                </div>
                <div style="font-size:11px;opacity:.6;text-transform:uppercase;
                    letter-spacing:.5px">
                    Orders
                </div>
            </div>
            <div style="text-align:center">
                <div style="font-size:26px;font-weight:800;font-family:var(--mono)">
                    ₹@((Model.TotalSpent / 1000).ToString("0"))K  @* ← Real Spent *@
                </div>
                <div style="font-size:11px;opacity:.6;text-transform:uppercase;
                    letter-spacing:.5px">
                    Spent
                </div>
            </div>
        </div>
    </div>

    @* ── Order Stats ── *@
    <div class="sg mb-18"
         style="grid-template-columns:repeat(auto-fit,minmax(170px,1fr))">
        <div class="sc am">
            <div class="sc-top">
                <div class="sc-ico am"><i class="fa-solid fa-hourglass-half"></i></div>
            </div>
            <div class="sc-val">@Model.PendingOrders</div>
            <div class="sc-lbl">Pending</div>
        </div>
        <div class="sc bl">
            <div class="sc-top">
                <div class="sc-ico bl"><i class="fa-solid fa-gear"></i></div>
            </div>
            <div class="sc-val">@Model.ProcessingOrders</div>
            <div class="sc-lbl">Processing</div>
        </div>
        <div class="sc cy">
            <div class="sc-top">
                <div class="sc-ico cy"><i class="fa-solid fa-truck"></i></div>
            </div>
            <div class="sc-val">@Model.InTransitOrders</div>
            <div class="sc-lbl">In Transit</div>
        </div>
        <div class="sc gr">
            <div class="sc-top">
                <div class="sc-ico gr"><i class="fa-solid fa-circle-check"></i></div>
            </div>
            <div class="sc-val">@Model.DeliveredOrders</div>
            <div class="sc-lbl">Delivered</div>
        </div>
    </div>

    @* ── Recent Orders + Notifications ── *@
    <div class="g2">
        <div class="card-sn">
            <div class="ch">
                <h3><i class="fa-solid fa-box-archive"></i> Recent Orders</h3>
                <a asp-controller="Customer"
                   asp-action="MyOrders"
                   class="btn-sn btn-o btn-sm">View All</a>
            </div>
            <div class="table-responsive">
                <table class="dt">
                    <thead>
                        <tr>
                            <th>Order ID</th>
                            <th>Items</th>
                            <th>Amount</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.RecentOrders.Any())
                        {
                            <tr>
                                <td colspan="4"
                                    class="text-center"
                                    style="padding:30px;color:var(--t3)">
                                    <i class="fa-solid fa-box-open"
                                       style="font-size:24px"></i>
                                    <div>No orders yet</div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var order in Model.RecentOrders)
                            {
                                <tr>
                                    <td style="font-family:var(--mono);
                                        color:var(--blue);font-weight:700">
                                        #ORD-@order.OrderId.ToString("D4")
                                    </td>
                                    <td>@order.ItemCount items</td>
                                    <td>
                                        <span style="font-family:var(--mono);
                                            font-weight:700">
                                            ₹@order.TotalAmount.ToString("N0")
                                        </span>
                                    </td>
                                    <td>
                                        <span class="bdg @order.StatusBadgeClass">
                                            @order.Status
                                        </span>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @* Notifications — Static for now *@
        <div class="card-sn">
            <div class="ch">
                <h3><i class="fa-solid fa-bell"></i> Notifications</h3>
                <span class="bdg bdg-pending">New</span>
            </div>
            <div class="cb">
                @if (Model.InTransitOrders > 0)
                {
                    <div class="notif-i">
                        <div class="nd2" style="background:var(--emerald)"></div>
                        <div class="notif-txt">
                            You have <strong>@Model.InTransitOrders</strong>
                            order(s) in transit!
                        </div>
                    </div>
                }
                @if (Model.PendingOrders > 0)
                {
                    <div class="notif-i">
                        <div class="nd2" style="background:var(--amber)"></div>
                        <div class="notif-txt">
                            <strong>@Model.PendingOrders</strong>
                            order(s) pending confirmation.
                        </div>
                    </div>
                }
                @if (!Model.RecentOrders.Any())
                {
                    <div class="notif-i">
                        <div class="nd2" style="background:var(--blue)"></div>
                        <div class="notif-txt">
                            Welcome to ShopNest! 🎉
                            <a asp-controller="Customer"
                               asp-action="Browse"
                               style="color:var(--blue);font-weight:600">
                                Start shopping
                            </a>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>