
@{
    ViewData["Title"] = "Notifications";
    Layout = "~/Views/Shared/_Customer.cshtml";
}

<div class="cnt page-anim">

    <div class="zpill cus"><i class="fa-solid fa-user-circle"></i> Customer Zone</div>
    <div class="ph"><div><h1>Notifications</h1><p>Stay updated on orders, offers, and account activity.</p></div><div class="ph-acts"><button class="btn-sn btn-o btn-sm">Mark All Read</button></div></div>
    <div class="card-sn">
        <div class="cb">
            <div class="notif-i"><div class="nd2" style="background:var(--cyan)"></div><div class="notif-txt">📦 Your order <strong>#ORD-8814</strong> has been shipped and is on its way! Expected delivery today by 7 PM.<small>2 hours ago · Order Update</small></div></div>
            <div class="notif-i"><div class="nd2" style="background:var(--rose)"></div><div class="notif-txt">🔥 <strong>SUMMER25</strong> — 25% off on Electronics! Limited time offer. Use code at checkout.<small>Today · Promotional Offer</small></div></div>
            <div class="notif-i"><div class="nd2" style="background:var(--emerald)"></div><div class="notif-txt">✅ Your order <strong>#ORD-8821</strong> has been delivered successfully. Rate your experience!<small>Yesterday · Order Update</small></div></div>
            <div class="notif-i"><div class="nd2" style="background:var(--amber)"></div><div class="notif-txt">⚠️ <strong>iPhone 15 Pro Max</strong> you wanted is back in stock! Only 3 units remaining.<small>2 days ago · Product Alert</small></div></div>
            <div class="notif-i"><div class="nd2" style="background:var(--t3)"></div><div class="notif-txt" style="color:var(--t3)">Your review for Nike Air Max 270 has been published.<small>3 days ago · Account</small></div></div>
        </div>
    </div>
</div>

